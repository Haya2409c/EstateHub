@{
    Layout = "_AgentLayout";
    ViewData["Title"] = "Packages";
    ViewData["PageHeading"] = "Packages & Subscription";
    var profile    = ViewBag.Profile as RealtorsPortal.Models.Entities.SellerProfile;
    var tier       = profile?.PackageTier ?? "Basic";
    var totalProps = (int)(ViewBag.TotalProps ?? 0);
    var maxList    = ViewBag.MaxListings as string ?? "10";
    var usedPct    = (int)(ViewBag.UsedPercent ?? 0);
}

<main class="p-6 lg:p-8 space-y-8">

    <!-- Current Plan Banner -->
    <div class="glass-card rounded-2xl p-6 border border-gold-500/20 flex flex-col sm:flex-row sm:items-center justify-between gap-4" data-aos="fade-down">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-gold-500/20 border border-gold-500/30 flex items-center justify-center shadow-gold-glow">
                <i class="fa-solid fa-crown text-2xl text-gold-500"></i>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Current Plan</p>
                <h2 class="text-2xl font-bold text-white">@tier Package</h2>
                <p class="text-sm text-gray-400">@totalProps / @maxList listings used</p>
            </div>
        </div>
        <div class="w-full sm:w-48">
            <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full bg-gold-500 rounded-full" style="width: @usedPct%"></div>
            </div>
            <p class="text-xs text-gray-400 mt-1 text-right">@usedPct% used</p>
        </div>
    </div>

    <!-- Plans -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Basic -->
        <div class="glass-card rounded-2xl p-8 flex flex-col @(tier == "Basic" ? "border-t-4 border-t-blue-500" : "")">
            <h3 class="text-xl font-bold text-white mb-1">Starter</h3>
            <p class="text-sm text-gray-400 mb-6">For new agents getting started</p>
            <p class="text-4xl font-bold text-white mb-8">Free</p>
            <ul class="space-y-3 mb-8 flex-1 text-sm text-gray-300">
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-blue-400"></i> Up to 10 Active Listings</li>
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-blue-400"></i> Basic Lead Notifications</li>
                <li class="flex items-center gap-3 opacity-40"><i class="fa-solid fa-xmark text-red-400"></i> Featured Listings</li>
                <li class="flex items-center gap-3 opacity-40"><i class="fa-solid fa-xmark text-red-400"></i> Priority Support</li>
            </ul>
            @if (tier == "Basic")
            {
                <div class="w-full py-3 rounded-xl bg-white/10 text-center text-white font-medium text-sm cursor-default">Current Plan</div>
            }
            else
            {
                <button class="w-full py-3 rounded-xl bg-blue-500/20 hover:bg-blue-500 text-white font-medium transition-theme border border-blue-500/50 text-sm" onclick="contactSupport()">Downgrade</button>
            }
        </div>

        <!-- Gold -->
        <div class="glass-card rounded-2xl p-8 flex flex-col relative @(tier == "Gold" ? "border-t-4 border-t-gold-500" : "border-t-4 border-t-gold-500/30") shadow-gold-glow">
            @if (tier != "Gold") { <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gold-500 text-navy-900 text-xs font-bold px-4 py-1 rounded-full">POPULAR</div> }
            <h3 class="text-xl font-bold text-white mb-1">Agency Elite</h3>
            <p class="text-sm text-gray-400 mb-6">For growing agents & teams</p>
            <p class="text-4xl font-bold text-white mb-1">$49 <span class="text-lg text-gray-500">/mo</span></p>
            <ul class="space-y-3 mb-8 flex-1 text-sm text-gray-200 mt-6">
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-gold-500"></i> Up to 50 Active Listings</li>
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-gold-500"></i> 5 Featured Listings</li>
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-gold-500"></i> Lead Management</li>
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-gold-500"></i> Priority Support</li>
            </ul>
            @if (tier == "Gold")
            {
                <div class="w-full py-3 rounded-xl bg-white/10 text-center text-white font-medium text-sm cursor-default">Current Plan</div>
            }
            else
            {
                <button class="w-full py-3 rounded-xl bg-gold-500 hover:bg-gold-600 text-navy-900 font-bold transition-theme text-sm" onclick="contactSupport()">Upgrade Now</button>
            }
        </div>

        <!-- Platinum -->
        <div class="glass-card rounded-2xl p-8 flex flex-col @(tier == "Platinum" ? "border-t-4 border-t-purple-500" : "")">
            <h3 class="text-xl font-bold text-white mb-1">Enterprise Plus</h3>
            <p class="text-sm text-gray-400 mb-6">For large brokerages</p>
            <p class="text-4xl font-bold text-white mb-1">$149 <span class="text-lg text-gray-500">/mo</span></p>
            <ul class="space-y-3 mb-8 flex-1 text-sm text-gray-300 mt-6">
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-purple-400"></i> Unlimited Listings</li>
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-purple-400"></i> 15 Featured Listings</li>
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-purple-400"></i> Advanced Lead Management</li>
                <li class="flex items-center gap-3"><i class="fa-solid fa-check text-purple-400"></i> VIP Support 24/7</li>
            </ul>
            @if (tier == "Platinum")
            {
                <div class="w-full py-3 rounded-xl bg-white/10 text-center text-white font-medium text-sm cursor-default">Current Plan</div>
            }
            else
            {
                <button class="w-full py-3 rounded-xl bg-purple-500/20 hover:bg-purple-500 text-white font-medium transition-theme border border-purple-500/50 text-sm" onclick="contactSupport()">Upgrade Now</button>
            }
        </div>

    </div>
    <p class="text-center text-gray-500 text-sm">To change your plan, contact our support team.</p>
</main>

@section Scripts {
<script>
    function contactSupport() {
        alert('Please contact support@luxeestates.com to change your plan.');
    }
</script>
}
