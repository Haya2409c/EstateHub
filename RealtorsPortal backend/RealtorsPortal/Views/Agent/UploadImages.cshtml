@{
    Layout = "_AgentLayout";
    ViewData["Title"] = "Property Images";
    ViewData["PageHeading"] = "Property Images";
    var properties = ViewBag.Properties as List<RealtorsPortal.Models.Entities.Property> ?? new();
    var selectedId = ViewBag.SelectedId as int?;
    var selectedProp = ViewBag.SelectedProperty as RealtorsPortal.Models.Entities.Property;
    var existingImages = ViewBag.ExistingImages as List<RealtorsPortal.Models.Entities.PropertyImage> ?? new();
}

<main class="p-6 lg:p-8 space-y-6">

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="glass-card rounded-xl p-4 text-center">
            <i class="fa-regular fa-images text-2xl text-blue-400 mb-2"></i>
            <p class="text-2xl font-bold text-white">@existingImages.Count</p>
            <p class="text-xs text-gray-400 uppercase tracking-wider">Total Images</p>
        </div>
        <div class="glass-card rounded-xl p-4 text-center">
            <i class="fa-solid fa-star text-2xl text-gold-500 mb-2"></i>
            <p class="text-2xl font-bold text-white">@existingImages.Count(i => i.IsPrimary)</p>
            <p class="text-xs text-gray-400 uppercase tracking-wider">Featured</p>
        </div>
        <div class="glass-card rounded-xl p-4 text-center">
            <i class="fa-solid fa-house text-2xl text-green-400 mb-2"></i>
            <p class="text-2xl font-bold text-white">@properties.Count</p>
            <p class="text-xs text-gray-400 uppercase tracking-wider">Properties</p>
        </div>
        <div class="glass-card rounded-xl p-4 text-center">
            <i class="fa-solid fa-check-circle text-2xl text-purple-400 mb-2"></i>
            <p class="text-2xl font-bold text-white">@(selectedProp?.Title?.Length > 0 ? "✓" : "—")</p>
            <p class="text-xs text-gray-400 uppercase tracking-wider">Selected</p>
        </div>
    </div>

    <!-- Property Selector -->
    <div class="glass-card rounded-2xl p-5">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Select Property</h2>
        <form method="get" asp-controller="Agent" asp-action="UploadImages">
            <select name="listingId" onchange="this.form.submit()" class="agent-input agent-select w-full max-w-md">
                <option value="">-- Select a property --</option>
                @foreach (var p in properties)
                {
                    <option value="@p.Id" selected="@(selectedId == p.Id)">@p.Title</option>
                }
            </select>
        </form>
    </div>

    @if (selectedProp != null)
    {
        <!-- Upload Form -->
        <div class="glass-card rounded-2xl p-6">
            <h2 class="text-lg font-bold text-white mb-4 border-b border-white/10 pb-3">
                Upload Images — <span class="text-gold-500">@selectedProp.Title</span>
            </h2>
            <form asp-controller="Agent" asp-action="UploadImagesConfirmed" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="listingId" value="@selectedId">
                <div class="border-2 border-dashed border-white/10 hover:border-gold-500/50 rounded-xl p-12 text-center transition-theme cursor-pointer group"
                     onclick="document.getElementById('mediaInput').click()">
                    <div class="w-20 h-20 rounded-full bg-gold-500/10 border border-gold-500/20 flex items-center justify-center mx-auto mb-4 group-hover:-translate-y-2 transition-transform duration-300">
                        <i class="fa-solid fa-cloud-arrow-up text-3xl text-gold-500"></i>
                    </div>
                    <p class="text-white font-semibold mb-1">Drag & Drop images here</p>
                    <p class="text-gray-500 text-sm mb-4">JPG, PNG, WEBP — max 5MB each</p>
                    <div class="flex justify-center gap-3">
                        <button type="button" class="btn-gold-agent text-sm" onclick="event.stopPropagation(); document.getElementById('mediaInput').click()">Browse Files</button>
                        <button type="submit" id="uploadBtn" class="btn-outline-agent text-sm hidden">Upload Selected</button>
                    </div>
                    <input type="file" id="mediaInput" name="Images" class="hidden" multiple accept="image/*">
                </div>
                <div id="selectedPreview" class="flex flex-wrap gap-3 mt-4"></div>
            </form>
        </div>

        <!-- Gallery -->
        <div class="glass-card rounded-2xl p-6">
            <h2 class="text-lg font-bold text-white mb-4 border-b border-white/10 pb-3">Image Gallery</h2>
            @if (!existingImages.Any())
            {
                <div class="text-center py-12 text-gray-500">
                    <i class="fa-regular fa-images text-5xl mb-3 block opacity-20"></i>
                    <p class="text-sm">No images yet. Upload some above.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                    @foreach (var img in existingImages)
                    {
                        <div class="relative group rounded-xl overflow-hidden aspect-square">
                            <img src="@img.Url" class="w-full h-full object-cover" onerror="this.src='/assets/images/new-property-1.jpg'">
                            @if (img.IsPrimary)
                            {
                                <span class="absolute top-2 left-2 bg-gold-500 text-navy-900 text-[10px] font-bold px-2 py-0.5 rounded-full">Primary</span>
                            }
                            <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity">
                                <form asp-controller="Agent" asp-action="DeleteImage" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="imageId" value="@img.Id">
                                    <input type="hidden" name="listingId" value="@selectedId">
                                    <button type="submit" class="w-10 h-10 rounded-full bg-red-500 hover:bg-red-600 text-white flex items-center justify-center">
                                        <i class="fa-solid fa-trash text-sm"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else if (!properties.Any())
    {
        <div class="glass-card rounded-2xl p-16 text-center">
            <i class="fa-solid fa-house-chimney text-6xl text-gray-600 mb-4"></i>
            <h3 class="text-xl font-bold text-white mb-2">No Properties Yet</h3>
            <p class="text-gray-400 mb-6">Add a property first, then upload images for it.</p>
            <a asp-controller="Agent" asp-action="CreateListing" class="btn-gold-agent">Add Property</a>
        </div>
    }
</main>

@section Scripts {
<script>
    document.getElementById('mediaInput')?.addEventListener('change', function() {
        const preview = document.getElementById('selectedPreview');
        const uploadBtn = document.getElementById('uploadBtn');
        preview.innerHTML = '';
        if (this.files.length > 0) {
            uploadBtn.classList.remove('hidden');
            Array.from(this.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = e => {
                    const d = document.createElement('div');
                    d.className = 'w-20 h-20 rounded-lg overflow-hidden flex-shrink-0';
                    d.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover">`;
                    preview.appendChild(d);
                };
                reader.readAsDataURL(file);
            });
        } else { uploadBtn.classList.add('hidden'); }
    });
</script>
}
