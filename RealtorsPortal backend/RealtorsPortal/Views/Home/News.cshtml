@{
    ViewData["Title"] = "News";
}
<!-- Header -->
    <section class="pt-32 pb-20 bg-deep border-b border-gray-200 relative overflow-hidden">
        <div class="absolute inset-0 bg-[#1E3A5F]/40"></div>
        <div class="container mx-auto px-6 text-center relative z-10">
            <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-4 block" data-aos="fade-up">Luxury Insights</span>
            <h1 class="text-white text-5xl md:text-6xl font-bold mb-6" data-aos="fade-up" data-aos-delay="100">Market <span class="text-gold italic font-normal">Trends & Lifestyle</span></h1>
            <p class="max-w-2xl mx-auto text-white/85" data-aos="fade-up" data-aos-delay="200">Expert analysis, investment guides, and a glimpse into the world's most exclusive lifestyles.</p>
        </div>
    </section>

    <!-- Blog Content -->
    <section class="py-20 container mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <!-- Main Feed -->
            <div class="lg:col-span-2 space-y-12">
                <!-- Blog Post 1 -->
                <article class="blog-card group" data-aos="fade-up">
                    <div class="h-96 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1571939228382-b2f2b585ce15?auto=format&fit=crop&w=600&q=80" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                    </div>
                    <div class="p-10">
                        <div class="flex items-center gap-4 mb-6">
                            <span class="px-4 py-1 bg-gold/10 text-gold text-xs font-bold uppercase tracking-widest rounded-full">Investment</span>
                            <span class="text-xs text-gray-500 font-bold uppercase tracking-widest">May 21, 2026</span>
                        </div>
                        <h2 class="text-3xl font-bold mb-6 hover:text-gold transition-colors cursor-pointer">The Rise of Private Islands: Why HNWIs are Seeking Ultimate Seclusion</h2>
                        <p class="text-[#4a5568] text-lg leading-relaxed mb-8">
                            As global connectivity increases, the demand for true privacy has reached an all-time high. We explore the current market for private islands in the Caribbean and South Pacific...
                        </p>
                        <button class="text-gold font-bold border-b border-gold pb-1 hover:text-[#2D4A8A] hover:border-[#2D4A8A] transition-all">Continue Reading</button>
                    </div>
                </article>

                <!-- Blog Post 2 -->
                <article class="blog-card group" data-aos="fade-up">
                    <div class="h-96 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=600&q=80" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                    </div>
                    <div class="p-10">
                        <div class="flex items-center gap-4 mb-6">
                            <span class="px-4 py-1 bg-gold/10 text-gold text-xs font-bold uppercase tracking-widest rounded-full">Architecture</span>
                            <span class="text-xs text-gray-500 font-bold uppercase tracking-widest">May 15, 2026</span>
                        </div>
                        <h2 class="text-3xl font-bold mb-6 hover:text-gold transition-colors cursor-pointer">Minimalist Masterpieces: The New Era of Desert Architecture</h2>
                        <p class="text-[#4a5568] text-lg leading-relaxed mb-8">
                            From Palm Springs to AlUla, modern architects are redefining how luxury interacts with the desert landscape through raw materials and sustainable design...
                        </p>
                        <button class="text-gold font-bold border-b border-gold pb-1 hover:text-[#2D4A8A] hover:border-[#2D4A8A] transition-all">Continue Reading</button>
                    </div>
                </article>
            </div>

            <!-- Sidebar -->
            <aside class="space-y-12">
                <div class="glass-panel p-8 rounded-3xl">
                    <h3 class="text-xl font-bold mb-6 border-b border-gray-200 pb-4">Categories</h3>
                    <ul class="space-y-4">
                        <li class="flex justify-between items-center group cursor-pointer">
                            <span class="group-hover:text-gold transition-colors">Market Updates</span>
                            <span class="text-xs text-gray-500">12</span>
                        </li>
                        <li class="flex justify-between items-center group cursor-pointer">
                            <span class="group-hover:text-gold transition-colors">Property Tips</span>
                            <span class="text-xs text-gray-500">08</span>
                        </li>
                        <li class="flex justify-between items-center group cursor-pointer">
                            <span class="group-hover:text-gold transition-colors">Investment News</span>
                            <span class="text-xs text-gray-500">24</span>
                        </li>
                    </ul>
                </div>

                <div class="glass-panel p-8 rounded-3xl">
                    <h3 class="text-xl font-bold mb-6 border-b border-gray-200 pb-4">Recent Posts</h3>
                    <div class="space-y-6">
                        <div class="flex gap-4 group cursor-pointer">
                            <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=600&q=80" class="w-20 h-20 rounded-xl object-cover">
                            <div>
                                <h4 class="font-bold text-sm group-hover:text-gold transition-colors">Miami Real Estate Boom</h4>
                                <p class="text-xs text-gray-500 mt-1">May 10, 2026</p>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </section>

    <!-- Footer -->
