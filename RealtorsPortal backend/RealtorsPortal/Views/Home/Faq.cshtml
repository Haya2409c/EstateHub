@{
    ViewData["Title"] = "FAQ";
}
<!-- Page Header -->
    <section class="pt-40 pb-20 relative overflow-hidden" style="background-color: #0F2040;">
        <div class="absolute inset-0">
            <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1920&q=80" class="w-full h-full object-cover opacity-20">
        </div>
        <!-- dark overlay div -->
        <div class="absolute inset-0 bg-[#0F2040]/70"></div>
    
    <div class="container mx-auto px-6 relative z-10 text-center">
        <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-4 block" data-aos="fade-up">Support</span>
        <h1 class="text-5xl md:text-7xl font-bold mb-6 text-white" data-aos="fade-up" data-aos-delay="100">
            Frequently Asked <span class="text-gold italic font-normal">Questions</span>
        </h1>
        <p class="max-w-2xl mx-auto text-lg text-white/85" data-aos="fade-up" data-aos-delay="200">
            Find answers to common questions about buying, selling, and managing luxury properties.
        </p>
    </div>
</section>

    <!-- FAQ Accordions -->
    <section class="py-20 container mx-auto px-6 max-w-4xl">
        
        <!-- Buying Section -->
        <div class="mb-16" data-aos="fade-up">
            <h2 class="text-2xl font-bold mb-6 flex items-center gap-3"><i class="fas fa-home text-gold"></i> Buying a Property</h2>
            <div class="space-y-4">
                <div class="faq-item glass-panel p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                    <div class="flex justify-between items-center faq-header">
                        <h4 class="font-bold text-lg group-hover:text-gold transition-colors">How do I start the process of buying a luxury property?</h4>
                        <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                    </div>
                    <div class="faq-content text-sm md:text-base hidden mt-4 text-[#4a5568] leading-relaxed">
                        To begin, simply reach out to our Concierge Team. We will schedule a private consultation to understand your specific lifestyle needs, preferred locations, and investment goals. From there, our elite agents will curate a bespoke portfolio of properties for your consideration.
                    </div>
                </div>
                <div class="faq-item glass-panel p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                    <div class="flex justify-between items-center faq-header">
                        <h4 class="font-bold text-lg group-hover:text-gold transition-colors">Can you arrange virtual tours for international buyers?</h4>
                        <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                    </div>
                    <div class="faq-content text-sm md:text-base hidden mt-4 text-[#4a5568] leading-relaxed">
                        Yes. For our international clientele, we offer highly detailed, private cinematic drone tours and interactive 3D walkthroughs. Our agents can also conduct live, private video viewings at your convenience.
                    </div>
                </div>
                <div class="faq-item glass-panel p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                    <div class="flex justify-between items-center faq-header">
                        <h4 class="font-bold text-lg group-hover:text-gold transition-colors">How do you verify the luxury properties listed?</h4>
                        <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                    </div>
                    <div class="faq-content text-sm md:text-base hidden mt-4 text-[#4a5568] leading-relaxed">
                        Every property on EstateHub undergoes a rigorous multi-point inspection. We verify the title, assess the architectural integrity, and evaluate the market value to ensure it meets our strict ultra-luxury standards before listing.
                    </div>
                </div>
            </div>
        </div>

        <!-- Selling Section -->
        <div class="mb-16" data-aos="fade-up">
            <h2 class="text-2xl font-bold mb-6 flex items-center gap-3"><i class="fas fa-key text-gold"></i> Selling a Property</h2>
            <div class="space-y-4">
                <div class="faq-item glass-panel p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                    <div class="flex justify-between items-center faq-header">
                        <h4 class="font-bold text-lg group-hover:text-gold transition-colors">How do I post my property for sale?</h4>
                        <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                    </div>
                    <div class="faq-content text-sm md:text-base hidden mt-4 text-[#4a5568] leading-relaxed">
                        You can begin by clicking "List Property" or "Register as Seller". Once you submit your property details, our team will review the application. If accepted, we will handle professional photography, marketing, and discrete placement across our global network.
                    </div>
                </div>
                <div class="faq-item glass-panel p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                    <div class="flex justify-between items-center faq-header">
                        <h4 class="font-bold text-lg group-hover:text-gold transition-colors">Do you offer off-market / discreet listings?</h4>
                        <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                    </div>
                    <div class="faq-content text-sm md:text-base hidden mt-4 text-[#4a5568] leading-relaxed">
                        Absolutely. A significant portion of our ultra-luxury transactions are conducted off-market. We can market your property exclusively to our private network of vetted high-net-worth individuals, maintaining your complete privacy.
                    </div>
                </div>
            </div>
        </div>

        <!-- Renting Section -->
        <div class="mb-16" data-aos="fade-up">
            <h2 class="text-2xl font-bold mb-6 flex items-center gap-3"><i class="fas fa-building text-gold"></i> Renting</h2>
            <div class="space-y-4">
                <div class="faq-item glass-panel p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                    <div class="flex justify-between items-center faq-header">
                        <h4 class="font-bold text-lg group-hover:text-gold transition-colors">Do you handle short-term luxury rentals?</h4>
                        <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                    </div>
                    <div class="faq-content text-sm md:text-base hidden mt-4 text-[#4a5568] leading-relaxed">
                        We specialize in premium long-term leases (12 months or more) and exclusive seasonal rentals. For short-term stays, we offer a select portfolio of fully serviced, ultra-luxury villas and penthouses in key global destinations.
                    </div>
                </div>
                <div class="faq-item glass-panel p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                    <div class="flex justify-between items-center faq-header">
                        <h4 class="font-bold text-lg group-hover:text-gold transition-colors">What is included in a premium rental?</h4>
                        <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                    </div>
                    <div class="faq-content text-sm md:text-base hidden mt-4 text-[#4a5568] leading-relaxed">
                        Premium rentals often include dedicated concierge services, security personnel, weekly cleaning, and maintenance staff. Specific inclusions vary by property and can be tailored to your requirements.
                    </div>
                </div>
            </div>
        </div>

        <!-- Account Section -->
        <div class="mb-16" data-aos="fade-up">
            <h2 class="text-2xl font-bold mb-6 flex items-center gap-3"><i class="fas fa-user-circle text-gold"></i> Account & Registration</h2>
            <div class="space-y-4">
                <div class="faq-item glass-panel p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                    <div class="flex justify-between items-center faq-header">
                        <h4 class="font-bold text-lg group-hover:text-gold transition-colors">How do I register as an Agent?</h4>
                        <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                    </div>
                    <div class="faq-content text-sm md:text-base hidden mt-4 text-[#4a5568] leading-relaxed">
                        Navigate to the Signup page and select "Agent" as your account type. You will need to provide your professional credentials and agency details. Our board reviews all agent applications to ensure they meet our standard of excellence.
                    </div>
                </div>
                <div class="faq-item glass-panel p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                    <div class="flex justify-between items-center faq-header">
                        <h4 class="font-bold text-lg group-hover:text-gold transition-colors">I forgot my password. How can I reset it?</h4>
                        <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                    </div>
                    <div class="faq-content text-sm md:text-base hidden mt-4 text-[#4a5568] leading-relaxed">
                        Click on "Sign In" and select the "Forgot Password" link. Enter your registered email address, and we will send you secure instructions to reset your access credentials.
                    </div>
                </div>
            </div>
        </div>

    </section>

    <!-- Footer -->

@section Scripts {
    <script>

        // FAQ Accordion Logic
        document.addEventListener('DOMContentLoaded', () => {
            const faqItems = document.querySelectorAll('.faq-item');
            
            faqItems.forEach(item => {
                const header = item.querySelector('.faq-header');
                const content = item.querySelector('.faq-content');
                const icon = item.querySelector('.faq-icon');
                
                header.addEventListener('click', () => {
                    const isOpen = !content.classList.contains('hidden');
                    
                    // Close all other items
                    faqItems.forEach(otherItem => {
                        const otherContent = otherItem.querySelector('.faq-content');
                        const otherIcon = otherItem.querySelector('.faq-icon');
                        otherContent.classList.add('hidden');
                        otherIcon.classList.remove('fa-minus');
                        otherIcon.classList.add('fa-plus');
                        otherItem.style.borderColor = '';
                    });
                    
                    // Toggle current item
                    if (!isOpen) {
                        content.classList.remove('hidden');
                        icon.classList.remove('fa-plus');
                        icon.classList.add('fa-minus');
                        item.style.borderColor = '#1E3A5F';
                    }
                });
            });
        });
    
    </script>
}
