@model RealtorsPortal.Models.ViewModels.Home.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}
<!-- Hero Section -->
    <section id="hero" class="hero-container !p-0">
        <div class="hero-video-wrapper">
            <video class="hero-bg-video active-video" autoplay muted loop playsinline preload="auto">
                <source src="/assets/videos/Villa.mp4" type="video/mp4">
            </video>
            <video class="hero-bg-video" autoplay muted loop playsinline preload="auto">
                <source src="/assets/videos/Villa2.mp4" type="video/mp4">
            </video>
            <video class="hero-bg-video" autoplay muted loop playsinline preload="auto">
                <source src="/assets/videos/Villa3.mp4" type="video/mp4">
            </video>
            <div class="hero-overlay"></div>
        </div>

        <div class="hero-content !z-[20]">
            <div class="toggle-container mb-8" data-aos="fade-down">
                <div class="toggle-btn active" onclick="toggleActive(this)">Buy</div>
                <div class="toggle-btn" onclick="toggleActive(this)">Rent</div>
            </div>

            <h1 class="text-white text-4xl md:text-8xl font-bold mb-6">
                Luxury Living <span class="luxury-text italic text-gold font-normal">Redefined</span>
            </h1>
            <p class="text-lg md:text-xl text-gray-300 mb-12 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="350">
                The world's most prestigious collection of ultra-luxury real estate, villas, and architectural masterpieces.
            </p>

            <!-- Search Card -->
            <div class="glass-panel search-card" data-aos="fade-up" data-aos-delay="450">
                <div class="search-input-group">
                    <label class="search-label">Location</label>
                    <select class="search-value">
                        <option value="dubai">Dubai, UAE</option>
                        <option value="ny">New York, USA</option>
                        <option value="london">London, UK</option>
                        <option value="miami">Miami, USA</option>
                    </select>
                </div>
                <div class="search-input-group">
                    <label class="search-label">Property Type</label>
                    <select class="search-value">
                        <option>Luxury Villa</option>
                        <option>Penthouse</option>
                        <option>Modern Mansion</option>
                        <option>Private Island</option>
                    </select>
                </div>
                <div class="search-input-group">
                    <label class="search-label">Price Range</label>
                    <select class="search-value">
                        <option>$1M - $5M</option>
                        <option>$5M - $10M</option>
                        <option>$10M - $50M</option>
                        <option>$50M+</option>
                    </select>
                </div>
                <button class="btn-gold flex items-center gap-2 group">
                    <i class="fas fa-search group-hover:scale-125 transition-transform"></i>
                    <span>Search</span>
                </button>
            </div>
        </div>

                <!-- Floating Stats -->
        <div class="stat-card glass-panel hidden 2xl:flex" style="top: 25%; left: 3%;" data-aos="zoom-in" data-aos-delay="600">
            <div class="stat-icon"><i class="fas fa-home"></i></div>
            <div><span class="stat-number">15K+</span><span class="stat-label">Properties</span></div>
        </div>

        <div class="stat-card glass-panel hidden 2xl:flex" style="top: 25%; right: 3%;" data-aos="zoom-in" data-aos-delay="650">
            <div class="stat-icon"><i class="fas fa-users"></i></div>
            <div><span class="stat-number">8K+</span><span class="stat-label">Happy Clients</span></div>
        </div>

        <div class="stat-card glass-panel hidden 2xl:flex" style="bottom: 10%; right: 5%;" data-aos="zoom-in" data-aos-delay="700">
            <div class="stat-icon"><i class="fas fa-map-marker-alt"></i></div>
            <div><span class="stat-number">120+</span><span class="stat-label">Cities</span></div>
        </div>
    </section>

    <!-- Luxury Statistics Counters -->
    <section class="bg-deep border-y border-gray-200">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 stats-grid">
                <div class="counter-card">
                    <span class="counter-number !text-white font-[800]" data-target="25" data-suffix="K+">0</span>
                    <p class="!text-[#E2E8F0] uppercase tracking-widest text-xs font-semibold">Properties Sold</p>
                </div>
                <div class="counter-card">
                    <span class="counter-number !text-white font-[800]" data-target="10" data-suffix="K+">0</span>
                    <p class="!text-[#E2E8F0] uppercase tracking-widest text-xs font-semibold">Happy Clients</p>
                </div>
                <div class="counter-card">
                    <span class="counter-number !text-white font-[800]" data-target="150" data-suffix="+">0</span>
                    <p class="!text-[#E2E8F0] uppercase tracking-widest text-xs font-semibold">Global Cities</p>
                </div>
                <div class="counter-card" data-aos="fade-up" data-aos-delay="400">
                    <span class="counter-number !text-white font-[800]" data-target="500" data-suffix="+">0</span>
                    <p class="!text-[#E2E8F0] uppercase tracking-widest text-xs font-semibold">Expert Agents</p>
                </div>
            </div>
        </div>
    </section>

    <!-- AI Recommendation Section -->
    <section class="bg-[#0F2040] border-b border-[rgba(255,255,255,0.1)] relative overflow-hidden py-24">
        <!-- Background Elements -->
        <div class="absolute top-[-20%] left-[-10%] w-96 h-96 bg-[#D4AF37]/20 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-20%] right-[-10%] w-96 h-96 bg-[#2D4A8A]/30 rounded-full blur-[120px]"></div>
        
        <div class="container mx-auto px-6 relative z-10">
            <div class="text-center mb-16" data-aos="fade-up">
                <span class="text-[#D4AF37] uppercase tracking-[0.3em] text-sm font-semibold mb-3 flex items-center justify-center gap-2">
                    <i class="fas fa-robot"></i> AI Assistant
                </span>
                <h2 class="text-4xl md:text-5xl font-bold mb-4" style="color: white !important;">Find Your Perfect Property with AI</h2>
                <p class="max-w-2xl mx-auto text-lg" style="color: rgba(255,255,255,0.8) !important;">Tell us your budget and preferences, and our advanced AI assistant will recommend the best properties for you.</p>
            </div>

            <div class="max-w-4xl mx-auto bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-10 shadow-2xl" data-aos="fade-up" data-aos-delay="100">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                    <!-- Budget Input -->
                    <div>
                        <label class="block text-white/70 text-sm font-bold mb-2 uppercase tracking-wider">Budget ($)</label>
                        <input type="number" id="ai-budget" placeholder="e.g., 5000000" class="w-full bg-[#1E3A5F]/50 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/40 focus:outline-none focus:border-[#D4AF37] transition-colors">
                    </div>
                    
                    <!-- City Dropdown -->
                    <div>
                        <label class="block text-white/70 text-sm font-bold mb-2 uppercase tracking-wider">City</label>
                        <select id="ai-city" class="w-full bg-[#1E3A5F]/50 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#D4AF37] transition-colors appearance-none">
                            <option value="Any">Any City</option>
                            <option value="Karachi">Karachi</option>
                            <option value="Dubai">Dubai</option>
                            <option value="London">London</option>
                            <option value="New York">New York</option>
                        </select>
                    </div>

                    <!-- Property Type -->
                    <div>
                        <label class="block text-white/70 text-sm font-bold mb-2 uppercase tracking-wider">Property Type</label>
                        <select id="ai-type" class="w-full bg-[#1E3A5F]/50 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#D4AF37] transition-colors appearance-none">
                            <option value="Any">Any Type</option>
                            <option value="House">House</option>
                            <option value="Apartment">Apartment</option>
                            <option value="Villa">Villa</option>
                            <option value="Commercial">Commercial</option>
                            <option value="Land">Land</option>
                        </select>
                    </div>

                    <!-- Transaction Type -->
                    <div>
                        <label class="block text-white/70 text-sm font-bold mb-2 uppercase tracking-wider">Status</label>
                        <select id="ai-status" class="w-full bg-[#1E3A5F]/50 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#D4AF37] transition-colors appearance-none">
                            <option value="buy">Buy</option>
                            <option value="rent">Rent</option>
                            <option value="sell">Sell</option>
                        </select>
                    </div>
                </div>

                <button onclick="generateAIRecommendation()" class="w-full py-4 bg-gradient-to-r from-[#D4AF37] to-[#AA8B2C] text-white font-bold text-lg rounded-xl hover:shadow-[0_0_20px_rgba(212,175,55,0.4)] transition-all transform hover:-translate-y-1 flex items-center justify-center gap-3">
                    <i class="fas fa-magic"></i> Get AI Recommendations
                </button>

                <!-- Recommendation Output Area (Hidden by default) -->
                <div id="ai-result-card" class="mt-8 bg-[#1E3A5F]/40 border border-[#D4AF37]/30 rounded-2xl p-6 md:p-8 hidden relative overflow-hidden transition-all duration-500 opacity-0 translate-y-4">
                    <div class="absolute top-0 left-0 w-1 h-full bg-[#D4AF37]"></div>
                    
                    <div class="flex items-center gap-3 mb-4">
                        <span class="bg-[#D4AF37]/20 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest border border-[#D4AF37]/30 flex items-center gap-1" style="color: white !important;"><i class="fas fa-check-circle" style="color: #D4AF37;"></i> AI Match Found</span>
                        <span id="ai-match-type" class="text-sm font-medium" style="color: white !important;"></span>
                    </div>
                    
                    <h3 id="ai-match-title" class="text-2xl font-bold mb-3" style="color: white !important;"></h3>
                    <p id="ai-match-desc" class="leading-relaxed mb-6" style="color: rgba(255,255,255,0.8) !important;"></p>
                    
                    <div class="flex flex-col sm:flex-row sm:items-center gap-6 border-t border-white/10 pt-6">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-[#D4AF37]"><i class="fas fa-map-marker-alt"></i></div>
                            <div>
                                <p class="text-xs uppercase tracking-wider" style="color: rgba(255,255,255,0.6) !important;">Suggested Location</p>
                                <p id="ai-match-location" class="font-bold" style="color: white !important;"></p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-[#D4AF37]"><i class="fas fa-tag"></i></div>
                            <div>
                                <p class="text-xs uppercase tracking-wider" style="color: rgba(255,255,255,0.6) !important;">Estimated Price Range</p>
                                <p id="ai-match-price" class="font-bold" style="color: white !important;"></p>
                            </div>
                        </div>
                        <div class="sm:ml-auto mt-4 sm:mt-0">
                            <a asp-controller="Properties" asp-action="Index" class="inline-block px-6 py-3 border border-[#D4AF37] hover:bg-[#D4AF37] font-bold rounded-xl transition-colors whitespace-nowrap text-center w-full sm:w-auto" style="color: #D4AF37 !important;" onmouseover="this.style.color='white'" onmouseout="this.style.color='#D4AF37'">View Properties <i class="fas fa-arrow-right ml-2"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Properties -->
    <section id="featured" class="container mx-auto px-6">
        <div class="section-title" data-aos="fade-up">
            <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-2 block">Exclusive Selection</span>
            <h2>Featured Residences</h2>
            <p class="text-gray-600">Explore our hand-picked selection of the world's most desirable ultra-luxury homes.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
            @if (Model.FeaturedProperties.Any())
            {
                @foreach (var prop in Model.FeaturedProperties)
                {
                    var statusLabel = prop.Status switch { "buy" => "For Buy", "rent" => "For Rent", "sell" => "For Sale", _ => "Listed" };
                    <div class="property-card flex flex-col h-full glass-panel bg-white border border-[#E2E8F0]" data-aos="fade-up">
                        <div class="property-img-container relative">
                            <img src="@prop.ThumbnailUrl" class="property-img" alt="@prop.Title"
                                 onerror="this.src='/assets/images/new-property-1.jpg'">
                            <span class="price-badge">PKR @prop.Price.ToString("N0")</span>
                            <span class="absolute top-3 left-3 bg-[#1E3A5F] text-white text-xs font-bold px-3 py-1 rounded-full">@statusLabel</span>
                        </div>
                        <div class="property-info flex flex-col flex-1">
                            <div class="flex justify-between items-start mb-2">
                                <h3 class="text-xl font-bold line-clamp-1">@prop.Title</h3>
                            </div>
                            <p class="text-gray-500 text-sm mb-4"><i class="fas fa-map-marker-alt text-gold mr-2"></i> @prop.Address</p>
                            <div class="flex items-center gap-6 border-y border-gray-200 py-4 mb-6">
                                @if (prop.Bedrooms.HasValue)
                                {
                                    <span class="text-xs text-gray-600"><i class="fas fa-bed text-gold mr-1"></i> @prop.Bedrooms Beds</span>
                                }
                                @if (prop.Bathrooms.HasValue)
                                {
                                    <span class="text-xs text-gray-600"><i class="fas fa-bath text-gold mr-1"></i> @prop.Bathrooms Baths</span>
                                }
                                @if (prop.AreaSqft.HasValue)
                                {
                                    <span class="text-xs text-gray-600"><i class="fas fa-expand text-gold mr-1"></i> @prop.AreaSqft sqft</span>
                                }
                            </div>
                            <a asp-controller="Properties" asp-action="Details" asp-route-id="@prop.Id"
                               class="block w-full text-center py-[12px] px-[20px] rounded-[8px] border border-[#1E3A5F] text-[#1E3A5F] bg-transparent font-bold text-sm hover:bg-[#1E3A5F] hover:text-white transition-colors duration-200 mt-auto">View Details</a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-3 text-center py-12 text-gray-500">
                    <i class="fas fa-home text-4xl text-gray-300 mb-4 block"></i>
                    <p>No properties listed yet. <a asp-controller="Account" asp-action="Register" class="text-[#2563EB] hover:underline">Become a seller</a> to add your first listing.</p>
                </div>
            }
        </div>

        <div class="text-center mt-16">
            <a asp-controller="Properties" asp-action="Index" class="btn-gold inline-block">View All Properties</a>
        </div>
    </section>

    <!-- Property Categories -->
    <section id="categories" class="bg-[#F4F6F9]">
        <div class="container mx-auto px-6">
            <div class="section-title" data-aos="fade-up">
                <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-2 block">Curation</span>
                <h2>Premium Categories</h2>
                <p class="text-gray-600">Find the architectural style that matches your unique vision of luxury living.</p>
            </div>

            <div class="marquee-wrapper">
                <div class="marquee-track">
                    <!-- Original 5 Cards -->
                    <div class="category-card" data-aos="zoom-in" data-aos-delay="100">
                        <img src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?auto=format&fit=crop&w=600&q=80" class="category-img" alt="House">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">House</h3>
                            <p class="text-sm text-white/80">450+ Listings</p>
                        </div>
                    </div>
                    <div class="category-card" data-aos="zoom-in" data-aos-delay="200">
                        <img src="https://images.unsplash.com/photo-1560185007-cde436f6a4d0?auto=format&fit=crop&w=600&q=80" class="category-img" alt="Apartment">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">Apartment</h3>
                            <p class="text-sm text-white/80">120+ Listings</p>
                        </div>
                    </div>
                    <div class="category-card" data-aos="zoom-in" data-aos-delay="300">
                        <img src="https://images.unsplash.com/photo-1571939228382-b2f2b585ce15?auto=format&fit=crop&w=600&q=80" class="category-img" alt="Villa">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">Villa</h3>
                            <p class="text-sm text-white/80">85+ Listings</p>
                        </div>
                    </div>
                    <div class="category-card" data-aos="zoom-in" data-aos-delay="400">
                        <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=600&q=80" class="category-img" alt="Commercial">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">Commercial Property</h3>
                            <p class="text-sm text-white/80">45+ Listings</p>
                        </div>
                    </div>
                    <div class="category-card" data-aos="zoom-in" data-aos-delay="500">
                        <img src="https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=600&q=80" class="category-img" alt="Land">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">Land</h3>
                            <p class="text-sm text-white/80">12+ Listings</p>
                        </div>
                    </div>
                    <!-- Duplicate 5 Cards for Infinite Loop -->
                    <div class="category-card">
                        <img src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?auto=format&fit=crop&w=600&q=80" class="category-img" alt="House">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">House</h3>
                            <p class="text-sm text-white/80">450+ Listings</p>
                        </div>
                    </div>
                    <div class="category-card">
                        <img src="https://images.unsplash.com/photo-1560185007-cde436f6a4d0?auto=format&fit=crop&w=600&q=80" class="category-img" alt="Apartment">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">Apartment</h3>
                            <p class="text-sm text-white/80">120+ Listings</p>
                        </div>
                    </div>
                    <div class="category-card">
                        <img src="https://images.unsplash.com/photo-1571939228382-b2f2b585ce15?auto=format&fit=crop&w=600&q=80" class="category-img" alt="Villa">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">Villa</h3>
                            <p class="text-sm text-white/80">85+ Listings</p>
                        </div>
                    </div>
                    <div class="category-card">
                        <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=600&q=80" class="category-img" alt="Commercial">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">Commercial Property</h3>
                            <p class="text-sm text-white/80">45+ Listings</p>
                        </div>
                    </div>
                    <div class="category-card">
                        <img src="https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=600&q=80" class="category-img" alt="Land">
                        <div class="category-overlay">
                            <h3 class="text-2xl font-bold">Land</h3>
                            <p class="text-sm text-white/80">12+ Listings</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section class="container mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div data-aos="fade-right">
                <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-2 block">Our Value</span>
                <h2 class="text-5xl font-bold mb-6">Why Choose <span class="text-gold">EstateHub</span></h2>
                <p class="text-gray-600 mb-10 text-lg leading-relaxed">
                    We redefine the art of high-end real estate by offering an unparalleled level of service, discretion, and access to the world's most exclusive properties.
                </p>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                    <div class="flex gap-4">
                        <div class="w-12 h-12 bg-[#1E3A5F]/10 rounded-full flex items-center justify-center shrink-0">
                            <i class="fas fa-shield-alt text-gold text-xl"></i>
                        </div>
                        <div>
                            <h4 class="font-bold mb-1">Verified Assets</h4>
                            <p class="text-sm text-gray-500">Every property undergoes rigorous inspection.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <div class="w-12 h-12 bg-[#1E3A5F]/10 rounded-full flex items-center justify-center shrink-0">
                            <i class="fas fa-user-tie text-gold text-xl"></i>
                        </div>
                        <div>
                            <h4 class="font-bold mb-1">Elite Agents</h4>
                            <p class="text-sm text-gray-500">Access to top 1% industry professionals.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="relative" data-aos="fade-left">
                <div class="rounded-3xl overflow-hidden border-2 border-[#1E3A5F]/20 p-4">
                    <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=600&q=80" class="rounded-2xl" alt="Luxe House">
                </div>
            </div>
        </div>
    </section>

    <!-- Latest Blog / News -->
    <section id="blog" class="bg-[#F4F6F9]">
        <div class="container mx-auto px-6">
            <div class="section-title" data-aos="fade-up">
                <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-2 block">Insights</span>
                <h2>Luxury Real Estate News</h2>
                <p class="text-gray-600">Stay informed about global market trends and investment opportunities.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
                <!-- Blog 1 -->
                <div class="blog-card bg-white">
                    <div class="blog-img-container">
                        <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=600&q=80" class="blog-img" alt="Blog">
                    </div>
                    <div class="p-8">
                        <span class="text-xs text-gold uppercase tracking-widest font-bold mb-2 block">Investment</span>
                        <h4 class="text-xl font-bold mb-4">The Future of Penthouses in 2026</h4>
                        <p class="text-sm text-gray-600 mb-6 line-clamp-2">Exploring why vertical luxury continues to dominate the high-end residential market across major financial hubs.</p>
                        <a asp-controller="Home" asp-action="News" class="text-sm font-bold border-b border-[#1E3A5F] pb-1 hover:text-gold transition-colors">Read Article</a>
                    </div>
                </div>
                <!-- Blog 2 -->
                <div class="blog-card bg-white">
                    <div class="blog-img-container">
                        <img src="https://images.unsplash.com/photo-1486325212027-8081e485255e?auto=format&fit=crop&w=600&q=80" class="blog-img" alt="Blog">
                    </div>
                    <div class="p-8">
                        <span class="text-xs text-gold uppercase tracking-widest font-bold mb-2 block">Architecture</span>
                        <h4 class="text-xl font-bold mb-4">Sustainable Luxury: Green Mansions</h4>
                        <p class="text-sm text-gray-600 mb-6 line-clamp-2">How architectural innovation is blending zero-emission technology with high-end aesthetic perfection.</p>
                        <a asp-controller="Home" asp-action="News" class="text-sm font-bold border-b border-[#1E3A5F] pb-1 hover:text-gold transition-colors">Read Article</a>
                    </div>
                </div>
                <!-- Blog 3 -->
                <div class="blog-card bg-white">
                    <div class="blog-img-container">
                        <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=600&q=80" class="blog-img" alt="Blog">
                    </div>
                    <div class="p-8">
                        <span class="text-xs text-gold uppercase tracking-widest font-bold mb-2 block">Market Tips</span>
                        <h4 class="text-xl font-bold mb-4">Discreet Acquisitions in Dubai</h4>
                        <p class="text-sm text-gray-600 mb-6 line-clamp-2">A guide to navigating high-value private sales and off-market opportunities in the world's luxury capital.</p>
                        <a asp-controller="Home" asp-action="News" class="text-sm font-bold border-b border-[#1E3A5F] pb-1 hover:text-gold transition-colors">Read Article</a>
                    </div>
                </div>
            </div>

            <div class="text-center mt-12">
                <a asp-controller="Home" asp-action="News" class="btn-gold inline-block">Read All Articles</a>
            </div>
        </div>
    </section>

    <!-- Featured Agents -->
    <section class="py-20 container mx-auto px-6">
        <div class="section-title text-center" data-aos="fade-up">
            <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-2 block">Our Experts</span>
            <h2 class="text-4xl font-bold">Featured Agents</h2>
            <p class="text-gray-600 mt-4 max-w-xl mx-auto">Connect with top-tier professionals dedicated to finding your perfect luxury home.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            <div class="glass-panel p-8 bg-white border border-gray-200 rounded-3xl text-center group hover:border-gold transition-all" data-aos="fade-up">
                <img src="/assets/images/agent_hifza.png" class="w-32 h-32 mx-auto mb-6 object-cover rounded-full border-4 border-[#1E3A5F]/20 grayscale group-hover:grayscale-0 transition-all">
                <h3 class="text-xl font-bold mb-1">HIFZA SHAHEEN</h3>
                <p class="text-gold text-xs font-bold uppercase tracking-widest mb-4">Managing Director</p>
                <a asp-controller="Agents" asp-action="Profile" asp-route-id="hifza" class="block w-full py-3 rounded-xl border border-[#1E3A5F]/30 text-gold text-sm font-bold hover:bg-[#2D4A8A] hover:text-white transition-all">View Profile</a>
            </div>
            <div class="glass-panel p-8 bg-white border border-gray-200 rounded-3xl text-center group hover:border-gold transition-all">
                <img src="/assets/images/agent_tayyaba.png" class="w-32 h-32 mx-auto mb-6 object-cover rounded-full border-4 border-[#1E3A5F]/20 grayscale group-hover:grayscale-0 transition-all">
                <h3 class="text-xl font-bold mb-1">TAYYABA ASHRAF</h3>
                <p class="text-gold text-xs font-bold uppercase tracking-widest mb-4">Senior Advisor</p>
                <a asp-controller="Agents" asp-action="Profile" asp-route-id="tayyaba" class="block w-full py-3 rounded-xl border border-[#1E3A5F]/30 text-gold text-sm font-bold hover:bg-[#2D4A8A] hover:text-white transition-all">View Profile</a>
            </div>
            <div class="glass-panel p-8 bg-white border border-gray-200 rounded-3xl text-center group hover:border-gold transition-all">
                <img src="/assets/images/agent_harmain.png" class="w-32 h-32 mx-auto mb-6 object-cover rounded-full border-4 border-[#1E3A5F]/20 grayscale group-hover:grayscale-0 transition-all">
                <h3 class="text-xl font-bold mb-1">HARMAIN</h3>
                <p class="text-gold text-xs font-bold uppercase tracking-widest mb-4">Global Specialist</p>
                <a asp-controller="Agents" asp-action="Profile" asp-route-id="harmain" class="block w-full py-3 rounded-xl border border-[#1E3A5F]/30 text-gold text-sm font-bold hover:bg-[#2D4A8A] hover:text-white transition-all">View Profile</a>
            </div>
        </div>
    </section>

    <!-- FAQ Preview -->
    <section class="py-20 bg-[#F4F6F9] border-y border-gray-200">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div data-aos="fade-right">
                    <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-2 block">Support</span>
                    <h2 class="text-4xl font-bold mb-6">Frequently Asked <span class="text-gold">Questions</span></h2>
                    <p class="text-gray-600 mb-8">Everything you need to know about buying or selling luxury real estate with EstateHub.</p>
                    <a asp-controller="Home" asp-action="Faq" class="btn-gold hidden lg:inline-block">View All FAQs</a>
                </div>
                <div class="space-y-4" data-aos="fade-left">
                    <div class="faq-item glass-panel bg-white border border-gray-200 p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                        <div class="flex justify-between items-center faq-header">
                            <h4 class="font-bold text-lg group-hover:text-gold transition-colors">How do I verify a luxury property?</h4>
                            <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                        </div>
                        <div class="faq-content hidden mt-4 text-gray-600 leading-relaxed">
                            Every property on EstateHub undergoes a rigorous multi-point inspection. We verify the title, assess the architectural integrity, and evaluate the market value to ensure it meets our strict ultra-luxury standards before listing.
                        </div>
                    </div>
                    <div class="faq-item glass-panel bg-white border border-gray-200 p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                        <div class="flex justify-between items-center faq-header">
                            <h4 class="font-bold text-lg group-hover:text-gold transition-colors">What are the fees for listing?</h4>
                            <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                        </div>
                        <div class="faq-content hidden mt-4 text-gray-600 leading-relaxed">
                            Our listing fees are structured to provide maximum value and are competitive within the ultra-luxury market. Please contact our Concierge Team for a tailored consultation and a breakdown of our comprehensive marketing services.
                        </div>
                    </div>
                    <div class="faq-item glass-panel bg-white border border-gray-200 p-6 rounded-2xl cursor-pointer hover:border-gold transition-colors group">
                        <div class="flex justify-between items-center faq-header">
                            <h4 class="font-bold text-lg group-hover:text-gold transition-colors">Do you handle international transactions?</h4>
                            <i class="fas fa-plus text-gold faq-icon transition-transform"></i>
                        </div>
                        <div class="faq-content hidden mt-4 text-gray-600 leading-relaxed">
                            Yes. We have a dedicated team specializing in international acquisitions and sales, ensuring seamless and discreet transactions across global jurisdictions.
                        </div>
                    </div>
                    
                    <!-- Mobile View All FAQs Button -->
                    <div class="pt-6 text-center lg:hidden w-full">
                        <a asp-controller="Home" asp-action="Faq" class="btn-gold block w-full text-center text-lg !py-4 rounded-xl">View All FAQs</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="container mx-auto px-6">
        <div class="cta-banner" data-aos="zoom-out">
            <h2 class="text-4xl md:text-6xl font-bold mb-8 text-white" style="color: white !important;">Ready to Find Your <br> <span class="clean-heading-text text-white" style="background: none !important; background-color: transparent !important; padding: 0;">Dream Property?</span></h2>
            <p class="text-lg max-w-2xl mx-auto mb-12 cta-subtitle">Join thousands of high-net-worth individuals who have discovered their perfect homes through our elite concierge service.</p>
            <div class="flex flex-wrap justify-center gap-6">
                <a href="#" class="cta-btn-primary">Register as Seller</a>
                <a href="#" class="cta-btn-secondary">Register as Agent</a>
            </div>
        </div>
    </section>

    <!-- Footer -->

@section Modal {
<!-- Property Detail Modal Overlay -->
    <div id="detailOverlay" class="detailOverlay">
        <div class="modal-content">
            <button class="modal-close-btn" onclick="closeOverlay()">
                <i class="fas fa-times"></i>
            </button>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 flex-1 overflow-y-auto pr-2 pb-4">
                <!-- Left Column -->
                <div class="flex flex-col gap-4">
                    <img id="detailImage" src="" alt="Property" class="w-full h-64 md:h-80 object-cover rounded-xl shadow-lg">
                    <div id="detailGallery" class="thumbnail-row"></div>
                    <iframe id="detailMap" width="100%" height="200" style="border:0; border-radius:12px; margin-top: 1rem;" loading="lazy"></iframe>
                </div>
                
                <!-- Right Column -->
                <div class="flex flex-col">
                    <h2 id="detailTitle" class="text-3xl font-bold text-[#1E3A5F] mb-2"></h2>
                    <p id="detailLocation" class="text-gray-500 mb-4"><i class="fas fa-map-marker-alt text-gold mr-2"></i><span></span></p>
                    <p id="detailPrice" class="text-2xl font-bold text-gold mb-6"></p>
                    
                    <div class="flex items-center gap-6 py-4 border-y border-gray-200 mb-4">
                        <div class="flex flex-col">
                            <span class="text-xs text-gray-500 uppercase tracking-wider">Bedrooms</span>
                            <span id="detailBeds" class="font-bold text-[#1E3A5F]"></span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xs text-gray-500 uppercase tracking-wider">Bathrooms</span>
                            <span id="detailBaths" class="font-bold text-[#1E3A5F]"></span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xs text-gray-500 uppercase tracking-wider">Area</span>
                            <span id="detailSqft" class="font-bold text-[#1E3A5F]"></span>
                        </div>
                    </div>
                    
                    <div id="detailExtraInfo" class="extra-info grid grid-cols-2 gap-3 mb-6 bg-gray-50 p-4 rounded-xl text-sm text-[#1E3A5F]">
                        <span>Type: <strong id="detailType"></strong></span>
                        <span id="detailYearWrapper" style="display:none;">Year Built: <strong id="detailYear"></strong></span>
                        <span id="detailParkingWrapper" style="display:none;">Parking: <strong id="detailParking"></strong></span>
                        <span id="detailPropIdWrapper" style="display:none;">Property ID: <strong id="detailPropId"></strong></span>
                    </div>
                    
                    <h3 class="font-bold text-xl text-[#1E3A5F] mb-3">Description</h3>
                    <p id="detailDescription" class="text-gray-600 text-sm leading-relaxed mb-6"></p>
                    
                    <h3 class="font-bold text-xl text-[#1E3A5F] mb-3">Features</h3>
                    <ul id="detailFeatures" class="grid grid-cols-2 gap-2 text-sm text-gray-600 mb-6">
                    </ul>
                    
                    <div class="agent-info bg-gray-50 p-4 rounded-xl border border-gray-200 flex items-center justify-between mt-auto">
                        <div class="flex items-center gap-4">
                            <img id="agentPhoto" src="" alt="Agent" class="w-12 h-12 rounded-full object-cover shadow-sm">
                            <div>
                                <h4 id="agentName" class="font-bold text-[#1E3A5F] text-sm"></h4>
                                <p id="agentPhone" class="text-xs text-gray-500"></p>
                            </div>
                        </div>
                        <a id="callAgentBtn" href="#" class="btn-gold !px-4 !py-2 text-xs flex items-center gap-2">
                            <i class="fas fa-phone"></i> Call
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Sticky Footer -->
            <div class="modal-footer">
                <button id="saveFavoriteBtn" class="btn-icon text-gray-400 hover:text-red-500 transition-colors text-xl"><i class="far fa-heart"></i></button>
                <button id="shareBtn" class="btn-icon text-gray-400 hover:text-blue-500 transition-colors text-xl"><i class="fas fa-share-alt"></i></button>
                <button id="scheduleVisitBtn" class="px-6 py-2.5 rounded-xl border border-[#1E3A5F] text-[#1E3A5F] font-bold text-sm hover:bg-[#1E3A5F] hover:text-white transition-colors ml-auto hidden sm:block">Schedule a Visit</button>
                <button id="detailActionBtn" class="px-6 py-2.5 rounded-xl bg-gold text-white font-bold text-sm hover:bg-yellow-600 transition-colors shadow-md">Inquire Now</button>
            </div>
        </div>
    </div>
}
