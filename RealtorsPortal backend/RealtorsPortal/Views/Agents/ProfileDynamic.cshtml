@model RealtorsPortal.Models.ViewModels.Agents.AgentProfileViewModel
@using RealtorsPortal.Models.Entities
@{
    ViewData["Title"] = Model.FullName + " - Agent Profile";
    var photo      = string.IsNullOrEmpty(Model.PhotoUrl) ? "/assets/images/agent1.png" : Model.PhotoUrl;
    var properties = ViewBag.AgentProperties as List<Property> ?? new List<Property>();
}

<!-- Agent Hero -->
<section class="pt-32 pb-20 bg-deep border-b border-gray-200 relative overflow-hidden">
    <div class="absolute inset-0 bg-[#1E3A5F]/40"></div>
    <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col md:flex-row items-center gap-10">
            <div class="relative flex-shrink-0">
                <img src="@photo" alt="@Model.FullName"
                     class="w-44 h-44 rounded-full object-cover border-4 border-gold shadow-xl"
                     onerror="this.src='/assets/images/agent1.png'">
                <div class="absolute bottom-2 right-2 w-10 h-10 bg-gold rounded-full flex items-center justify-center border-4 border-deep">
                    <i class="fas fa-check text-sm text-white"></i>
                </div>
            </div>
            <div class="text-center md:text-left">
                <span class="text-gold uppercase tracking-[0.3em] text-xs font-semibold mb-2 block">Licensed Agent</span>
                <h1 class="text-white text-4xl md:text-5xl font-bold mb-4">@Model.FullName</h1>
                <div class="flex flex-wrap gap-6 justify-center md:justify-start text-white/80 text-sm">
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <span><i class="fas fa-envelope text-gold mr-2"></i>@Model.Email</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <span><i class="fas fa-phone text-gold mr-2"></i>@Model.Phone</span>
                    }
                    <span><i class="fas fa-home text-gold mr-2"></i>@properties.Count Active Listing@(properties.Count != 1 ? "s" : "")</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Listings & Contact -->
<section class="py-20 container mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Agent's Listings -->
        <div class="lg:col-span-2">
            <h2 class="text-2xl font-bold mb-8">Active Listings</h2>
            @if (!properties.Any())
            {
                <div class="glass-panel rounded-2xl p-12 text-center text-gray-500">
                    <i class="fas fa-home text-3xl mb-4 opacity-30"></i>
                    <p>No active listings yet.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    @foreach (var prop in properties)
                    {
                        var thumb = prop.Images?.FirstOrDefault(i => i.IsPrimary)?.Url
                                 ?? prop.Images?.OrderBy(i => i.SortOrder).FirstOrDefault()?.Url
                                 ?? "/assets/images/new-property-1.jpg";
                        <a asp-action="Details" asp-controller="Properties" asp-route-id="@prop.Id"
                           class="glass-panel rounded-2xl overflow-hidden group hover:border-gold transition-all block">
                            <div class="h-48 bg-cover bg-center" style="background-image:url('@thumb')"></div>
                            <div class="p-5">
                                <h3 class="font-bold text-lg mb-1 group-hover:text-gold transition-colors">@prop.Title</h3>
                                <p class="text-gold font-bold mb-1">$@prop.Price.ToString("N0")</p>
                                <p class="text-gray-500 text-sm">@prop.Address</p>
                                @if (prop.Bedrooms.HasValue || prop.Bathrooms.HasValue)
                                {
                                    <div class="flex gap-4 mt-3 text-xs text-gray-400">
                                        @if (prop.Bedrooms.HasValue)
                                        {
                                            <span><i class="fas fa-bed mr-1"></i>@prop.Bedrooms bd</span>
                                        }
                                        @if (prop.Bathrooms.HasValue)
                                        {
                                            <span><i class="fas fa-bath mr-1"></i>@prop.Bathrooms ba</span>
                                        }
                                    </div>
                                }
                            </div>
                        </a>
                    }
                </div>
            }
        </div>

        <!-- Contact Form -->
        <div>
            <div class="glass-panel p-8 rounded-3xl sticky top-28">
                <h3 class="text-xl font-bold mb-6">Contact @Model.FullName.Split(' ')[0]</h3>

                @if (TempData["EnquirySent"] != null)
                {
                    <div class="mb-4 p-3 rounded-lg bg-green-50 text-green-700 text-sm border border-green-200">
                        <i class="fas fa-check-circle mr-2"></i>@TempData["EnquirySent"]
                    </div>
                }

                <form asp-action="ContactAgent" asp-controller="Agents" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="AgentId" value="@ViewBag.AgentId" />
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                        <input type="text" name="FullName" required class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-gold outline-none transition-colors">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                        <input type="email" name="Email" required class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-gold outline-none transition-colors">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                        <input type="tel" name="Phone" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-gold outline-none transition-colors">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                        <textarea name="Message" rows="4" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-gold outline-none transition-colors resize-none" placeholder="I'm interested in your listings..."></textarea>
                    </div>
                    <button type="submit" class="w-full btn-gold py-3 font-semibold text-sm">
                        Send Message
                    </button>
                </form>
            </div>
        </div>

    </div>
</section>

<!-- Footer -->
