@{
    ViewData["Title"] = "Agent Profile";
}
<!-- Agent Profile Header -->
    <section class="pt-40 pb-20 bg-deep relative overflow-hidden">
        <div class="absolute inset-0 opacity-10">
            <img src="https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=1920&q=80" class="w-full h-full object-cover">
        </div>
        <div class="absolute inset-0 bg-[#1E3A5F]/60"></div>
        <div class="container mx-auto px-6 relative z-10">
            <div class="glass-panel p-8 md:p-12 rounded-3xl flex flex-col md:flex-row gap-10 items-center md:items-start w-full overflow-hidden" data-aos="fade-up">
                <!-- Profile Image -->
                <div class="shrink-0 relative">
                    <img src="/assets/images/agent_hifza.png" class="w-48 h-48 md:w-64 md:h-64 object-cover rounded-2xl border-4 border-gold/20 shadow-[0_0_40px_rgba(212,175,55,0.2)]">
                    <div class="absolute -bottom-4 -right-4 w-12 h-12 bg-gold rounded-full flex items-center justify-center border-4 border-matte" title="Verified Elite Agent">
                        <i class="fas fa-check text-matte"></i>
                    </div>
                </div>
                
                <!-- Profile Info -->
                <div class="flex-grow text-center md:text-left">
                    <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-2 block">EstateHub Elite</span>
                    <h1 class="text-white text-4xl md:text-6xl font-bold mb-4 break-words w-full">HIFZA SHAHEEN</h1>
                    <p class="text-xl text-white/80 mb-8"><i class="fas fa-building text-gold mr-2"></i> Managing Director</p>
                    
                    <div class="flex flex-col md:flex-row justify-center md:justify-start gap-6 mb-8 w-full">
                        <div class="flex items-center gap-3 max-w-full">
                            <div class="w-10 h-10 shrink-0 rounded-full bg-white flex items-center justify-center text-gold"><i class="fas fa-phone-alt"></i></div>
                            <div class="min-w-0">
                                <p class="text-xs text-gray-500 uppercase">Direct Line</p>
                                <p class="font-bold">+1 (555) 123-4567</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3 max-w-full">
                            <div class="w-10 h-10 shrink-0 rounded-full bg-white flex items-center justify-center text-gold"><i class="far fa-envelope"></i></div>
                            <div class="min-w-0 flex-1">
                                <p class="text-xs text-gray-500 uppercase">Email Address</p>
                                <p class="font-bold break-all">alexander@luxeestate.com</p>
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-4 justify-center md:justify-start border-t border-gray-200 pt-6">
                        <a href="#" class="w-10 h-10 rounded-full bg-white flex items-center justify-center hover:bg-gold hover:text-white transition-all"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-white flex items-center justify-center hover:bg-gold hover:text-white transition-all"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-white flex items-center justify-center hover:bg-gold hover:text-white transition-all"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>

                <!-- Contact CTA -->
                <div class="shrink-0 w-full md:w-auto">
                    <a href="#contact-agent" class="w-full md:w-auto btn-gold text-center block !py-4 !px-8 shadow-[0_10px_30px_rgba(212,175,55,0.3)]">Message Agent</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="py-20 container mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            <!-- Left Column: About & Listings -->
            <div class="lg:col-span-2">
                <!-- About Section -->
                <div class="mb-16" data-aos="fade-up">
                    <h2 class="text-2xl font-bold mb-6 border-b border-gray-200 pb-4">About HIFZA SHAHEEN</h2>
                    <div class="prose prose-invert prose-gold max-w-none text-[#4a5568] leading-relaxed">
                        <p>With over 15 years of experience in the ultra-luxury real estate market, HIFZA SHAHEEN has established himself as one of the most trusted advisors for high-net-worth individuals globally. Based out of Dubai and New York, he specializes in off-market transactions, private islands, and penthouse acquisitions.</p>
                        <p>His discreet approach, paired with an unparalleled global network, ensures that his clients have exclusive access to properties that are rarely available to the public. Alexander's recent achievements include the record-breaking sale of the Zenith Mansion in Palm Jumeirah.</p>
                    </div>
                </div>

                <!-- Active Listings -->
                <div data-aos="fade-up">
                    <div class="flex justify-between items-end border-b border-gray-200 pb-4 mb-8">
                        <h2 class="text-2xl font-bold">Active Listings</h2>
                        <span class="text-gold font-bold">4 Properties</span>
                    </div>
                    
                    <div id="agent-properties-grid" class="grid grid-cols-1 md:grid-cols-2 gap-8"></div>
                    </div>
                </div>

            <!-- Right Column: Contact Form -->
            <div class="lg:col-span-1" id="contact-agent">
                <div class="glass-panel p-8 rounded-3xl sticky top-32" data-aos="fade-left">
                    <h3 class="text-xl font-bold mb-6 flex items-center gap-3"><i class="far fa-envelope text-gold"></i> Send a Message</h3>
                    <form action="#">
                        <div class="mb-4">
                            <label class="block text-xs text-[#4a5568] mb-2 uppercase tracking-widest font-bold">Your Name</label>
                            <input type="text" placeholder="John Doe" class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-navy outline-none text-gray-800 transition-colors" required>
                        </div>
                        <div class="mb-4">
                            <label class="block text-xs text-[#4a5568] mb-2 uppercase tracking-widest font-bold">Your Email</label>
                            <input type="email" placeholder="john@example.com" class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-navy outline-none text-gray-800 transition-colors" required>
                        </div>
                        <div class="mb-4">
                            <label class="block text-xs text-[#4a5568] mb-2 uppercase tracking-widest font-bold">Phone (Optional)</label>
                            <input type="tel" placeholder="+1 234 567 890" class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-navy outline-none text-gray-800 transition-colors">
                        </div>
                        <div class="mb-6">
                            <label class="block text-xs text-[#4a5568] mb-2 uppercase tracking-widest font-bold">Message</label>
                            <textarea rows="5" placeholder="I am interested in..." class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-navy outline-none text-gray-800 transition-colors resize-none" required></textarea>
                        </div>
                        <button type="submit" class="w-full btn-gold !py-4 font-bold shadow-[0_10px_20px_rgba(212,175,55,0.2)]">Send Message</button>
                    </form>
                </div>
            </div>

        </div>
    </section>

        <!-- Property Detail Modal Overlay -->
    <div id="detailOverlay" class="detailOverlay">
        <div class="modal-content">
            <button class="modal-close-btn" onclick="closeOverlay()">
                <i class="fas fa-times"></i>
            </button>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 flex-1 overflow-y-auto pr-2 pb-4">
                <!-- Left Column -->
                <div class="flex flex-col gap-4">
                    <img id="detailImage" src="" alt="Property" class="w-full h-64 md:h-80 object-cover rounded-xl shadow-lg">
                    <div id="detailGallery" class="thumbnail-row"></div>
                    <iframe id="detailMap" width="100%" height="200" style="border:0; border-radius:12px; margin-top: 1rem;" loading="lazy"></iframe>
                </div>
                
                <!-- Right Column -->
                <div class="flex flex-col">
                    <h2 id="detailTitle" class="text-3xl font-bold text-[#1E3A5F] mb-2"></h2>
                    <p id="detailLocation" class="text-gray-500 mb-4"><i class="fas fa-map-marker-alt text-gold mr-2"></i><span></span></p>
                    <p id="detailPrice" class="text-2xl font-bold text-gold mb-6"></p>
                    
                    <div class="flex items-center gap-6 py-4 border-y border-gray-200 mb-4">
                        <div class="flex flex-col">
                            <span class="text-xs text-gray-500 uppercase tracking-wider">Bedrooms</span>
                            <span id="detailBeds" class="font-bold text-[#1E3A5F]"></span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xs text-gray-500 uppercase tracking-wider">Bathrooms</span>
                            <span id="detailBaths" class="font-bold text-[#1E3A5F]"></span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xs text-gray-500 uppercase tracking-wider">Area</span>
                            <span id="detailSqft" class="font-bold text-[#1E3A5F]"></span>
                        </div>
                    </div>
                    
                    <div id="detailExtraInfo" class="extra-info grid grid-cols-2 gap-3 mb-6 bg-gray-50 p-4 rounded-xl text-sm text-[#1E3A5F]">
                        <span>Type: <strong id="detailType"></strong></span>
                        <span id="detailYearWrapper" style="display:none;">Year Built: <strong id="detailYear"></strong></span>
                        <span id="detailParkingWrapper" style="display:none;">Parking: <strong id="detailParking"></strong></span>
                        <span id="detailPropIdWrapper" style="display:none;">Property ID: <strong id="detailPropId"></strong></span>
                    </div>
                    
                    <h3 class="font-bold text-xl text-[#1E3A5F] mb-3">Description</h3>
                    <p id="detailDescription" class="text-gray-600 text-sm leading-relaxed mb-6"></p>
                    
                    <h3 class="font-bold text-xl text-[#1E3A5F] mb-3">Features</h3>
                    <ul id="detailFeatures" class="grid grid-cols-2 gap-2 text-sm text-gray-600 mb-6">
                    </ul>
                    
                    <div class="agent-info bg-gray-50 p-4 rounded-xl border border-gray-200 flex items-center justify-between mt-auto">
                        <div class="flex items-center gap-4">
                            <img id="agentPhoto" src="" alt="Agent" class="w-12 h-12 rounded-full object-cover shadow-sm">
                            <div>
                                <h4 id="agentName" class="font-bold text-[#1E3A5F] text-sm"></h4>
                                <p id="agentPhone" class="text-xs text-gray-500"></p>
                            </div>
                        </div>
                        <a id="callAgentBtn" href="#" class="btn-gold !px-4 !py-2 text-xs flex items-center gap-2">
                            <i class="fas fa-phone"></i> Call
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Sticky Footer -->
            <div class="modal-footer">
                <button id="saveFavoriteBtn" class="btn-icon text-gray-400 hover:text-red-500 transition-colors text-xl"><i class="far fa-heart"></i></button>
                <button id="shareBtn" class="btn-icon text-gray-400 hover:text-blue-500 transition-colors text-xl"><i class="fas fa-share-alt"></i></button>
                <button id="scheduleVisitBtn" class="px-6 py-2.5 rounded-xl border border-[#1E3A5F] text-[#1E3A5F] font-bold text-sm hover:bg-[#1E3A5F] hover:text-white transition-colors ml-auto hidden sm:block">Schedule a Visit</button>
                <button id="detailActionBtn" class="px-6 py-2.5 rounded-xl bg-gold text-white font-bold text-sm hover:bg-yellow-600 transition-colors shadow-md">Inquire Now</button>
            </div>
        </div>
    </div>

    <!-- Footer -->

@section Scripts {
    <script>

        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('agent-properties-grid');
            if(container && typeof window.properties !== 'undefined') {
                const agentProps = window.properties.filter(p => [4, 5, 6].includes(p.id));
                container.innerHTML = agentProps.map(p => {
                    return `
                        <div class="property-card glass-panel group">
                            <div class="property-img-container">
                                <img src="${p.img}" class="property-img" alt="${p.type}">
                                <span class="price-badge">$${p.price.toLocaleString()}</span>
                            </div>
                            <div class="property-info p-6">
                                <div class="flex justify-between items-start mb-2">
                                    <h3 class="text-xl font-bold">${p.name}</h3>
                                    <span class="px-3 py-1 bg-white rounded-full text-xs text-gold border border-gold/20 capitalize">${p.type}</span>
                                </div>
                                <p class="text-[#4a5568] text-sm mb-4"><i class="fas fa-map-marker-alt text-gold mr-2"></i> ${p.city}</p>
                                <div class="flex items-center gap-6 border-y border-gray-200 py-4 mb-6">
                                    <span class="text-xs text-[#4a5568]"><i class="fas fa-bed text-gold mr-1"></i> ${p.beds}</span>
                                    <span class="text-xs text-[#4a5568]"><i class="fas fa-bath text-gold mr-1"></i> ${p.baths}</span>
                                    <span class="text-xs text-[#4a5568]"><i class="fas fa-expand text-gold mr-1"></i> ${(p.sqft/1000).toFixed(1)}k sqft</span>
                                </div>
                                <button onclick="openDetail(${p.id})" class="block w-full text-center py-[12px] px-[20px] rounded-[8px] bg-[#1a2e4a] text-white font-bold text-sm hover:bg-[#2D4A8A] transition-colors duration-200 mt-auto">View Details</button>
                            </div>
                        </div>
                    `;
                }).join('');
            }
        });
    
    </script>
}
