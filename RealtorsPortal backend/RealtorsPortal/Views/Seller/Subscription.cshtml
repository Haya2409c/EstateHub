@{
    Layout = "_SellerLayout";
    ViewData["Title"] = "Packages & Subscription";
    ViewData["PageHeading"] = "Packages & Subscription";
    var profile = ViewBag.Profile as RealtorsPortal.Models.Entities.SellerProfile;
    var tier = profile?.PackageTier ?? "Basic";
    var totalProps = (int)(ViewBag.TotalProps ?? 0);
    var maxListings = ViewBag.MaxListings?.ToString() ?? "10";
    var listingsLeft = ViewBag.ListingsLeft?.ToString() ?? "10";
    var usedPercent = (int)(ViewBag.UsedPercent ?? 0);
}

<main class="flex-1 p-6 max-w-7xl mx-auto w-full overflow-x-hidden">

    <!-- Page Header -->
    <div class="mb-8" data-aos="fade-down">
        <nav class="flex items-center gap-2 text-sm font-poppins text-[#718096] mb-3">
            <a asp-controller="Seller" asp-action="Index" class="hover:text-[#2563EB] transition-colors">Dashboard</a>
            <i class="fa-solid fa-chevron-right text-xs"></i>
            <span class="text-[#1E3A5F] font-medium">Packages & Subscription</span>
        </nav>
        <h1 class="font-outfit font-bold text-3xl text-[#1E3A5F] mb-2">Manage Your Subscription</h1>
        <p class="font-poppins text-[#718096]">Upgrade your plan to unlock more listings, featured spots, and premium tools.</p>
    </div>

    <!-- Current Package Overview & Stats -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-12 items-start">
        <!-- Current Package Card -->
        <div class="lg:col-span-4 bg-gradient-to-br from-[#1E3A5F] to-[#112240] rounded-xl p-6 text-white shadow-xl relative overflow-hidden group border border-[#2563EB]/30 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300" data-aos="fade-right">
            <div class="absolute -right-16 -top-16 w-48 h-48 bg-[#2563EB]/10 rounded-full blur-3xl group-hover:bg-[#2563EB]/20 transition-all"></div>
            <div class="relative z-10 flex flex-col h-full justify-between">
                <div>
                    <div class="flex justify-between items-start mb-6">
                        <div>
                            <span class="bg-[#2563EB]/20 text-[#93C5FD] text-xs px-2.5 py-1 rounded border border-[#2563EB]/30 uppercase tracking-widest font-bold">Current Plan</span>
                            <h2 class="font-outfit font-bold text-3xl mt-2 text-white">@tier Package</h2>
                        </div>
                        <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center border border-white/20 shadow-inner">
                            <i class="fa-solid fa-star text-[#93C5FD] text-xl"></i>
                        </div>
                    </div>
                    <p class="text-white/70 text-sm font-poppins mb-8">You are on the @tier Package. Up to @maxListings listings included.</p>
                </div>
                <div class="mt-auto">
                    <div class="mb-5">
                        <div class="flex justify-between text-sm font-poppins mb-2">
                            <span class="text-white/90 font-medium">Listings Used</span>
                            <span class="text-[#93C5FD] font-bold">@totalProps / @maxListings</span>
                        </div>
                        <div class="w-full bg-white/10 rounded-full h-3 overflow-hidden shadow-inner">
                            <div class="bg-gradient-to-r from-[#2563EB] to-[#60A5FA] h-3 rounded-full" style="width: @usedPercent%"></div>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 text-sm text-white/60 font-poppins">
                        @if (profile?.PackageExpiry.HasValue == true)
                        {
                            <i class="fa-solid fa-calendar text-[#93C5FD]"></i><text>Expires @profile.PackageExpiry.Value.ToString("MMM dd, yyyy")</text>
                        }
                        else
                        {
                            <i class="fa-solid fa-infinity text-[#93C5FD]"></i><text> No expiry on @tier plan</text>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="lg:col-span-8 grid grid-cols-2 md:grid-cols-4 gap-4" data-aos="fade-left">
            <div class="glass-panel p-4 flex flex-col justify-center text-left relative overflow-hidden group hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
                <div class="w-10 h-10 rounded-lg bg-[#F4F6F9] text-[#2563EB] flex items-center justify-center mb-3 shadow-sm group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-wallet text-xl"></i>
                </div>
                <div class="font-outfit font-bold text-3xl text-[#1E3A5F] leading-none mb-1">$0</div>
                <div class="text-[#1E3A5F] text-xs font-poppins font-semibold mb-0.5">Total Spent</div>
                <div class="text-[10px] text-[#718096] font-poppins">Lifetime Value</div>
            </div>
            <div class="glass-panel p-4 flex flex-col justify-center text-left relative overflow-hidden group hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
                <div class="w-10 h-10 rounded-lg bg-[#F4F6F9] text-[#D4AF37] flex items-center justify-center mb-3 shadow-sm group-hover:scale-110 transition-transform">
                    <i class="fa-regular fa-hourglass-half text-xl"></i>
                </div>
                <div class="font-outfit font-bold text-3xl text-[#1E3A5F] leading-none mb-1">∞</div>
                <div class="text-[#1E3A5F] text-xs font-poppins font-semibold mb-0.5">Days Remaining</div>
                <div class="text-[10px] text-[#718096] font-poppins">No Expiry</div>
            </div>
            <div class="glass-panel p-4 flex flex-col justify-center text-left relative overflow-hidden group hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
                <div class="w-10 h-10 rounded-lg bg-[#F4F6F9] text-green-500 flex items-center justify-center mb-3 shadow-sm group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-house-circle-check text-xl"></i>
                </div>
                <div class="font-outfit font-bold text-3xl text-[#1E3A5F] leading-none mb-1">@listingsLeft</div>
                <div class="text-[#1E3A5F] text-xs font-poppins font-semibold mb-0.5">Listings Left</div>
                <div class="text-[10px] text-[#718096] font-poppins">Available Quota</div>
            </div>
            <div class="glass-panel p-4 flex flex-col justify-center text-left relative overflow-hidden group hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
                <div class="w-10 h-10 rounded-lg bg-[#F4F6F9] text-purple-500 flex items-center justify-center mb-3 shadow-sm group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-star text-xl"></i>
                </div>
                <div class="font-outfit font-bold text-3xl text-[#1E3A5F] leading-none mb-1">0</div>
                <div class="text-[#1E3A5F] text-xs font-poppins font-semibold mb-0.5">Featured Spots</div>
                <div class="text-[10px] text-[#718096] font-poppins">Not Available</div>
            </div>
        </div>
    </div>

    <!-- Available Package Pricing Cards -->
    <div class="mb-16">
        <div class="text-center mb-10" data-aos="fade-up">
            <h2 class="font-outfit font-bold text-3xl text-[#1E3A5F] mb-3">Upgrade Your Potential</h2>
            <p class="font-poppins text-[#718096]">Choose the perfect plan to grow your real estate business.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center max-w-5xl mx-auto">
            <!-- Basic Plan -->
            <div class="@(tier == "Basic" ? "bg-[#1E3A5F] text-white border-2 border-[#2563EB] transform md:scale-105 z-10" : "glass-panel") p-8 rounded-2xl shadow-2xl flex flex-col relative" data-aos="fade-up" data-aos-delay="100">
                @if (tier == "Basic") { <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-[#2563EB] to-[#1D4ED8] text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full shadow-lg whitespace-nowrap">Current Plan</div> }
                <h3 class="font-outfit font-bold text-xl mb-2 mt-2 text-white">Basic</h3>
                <p class="text-sm text-white/70 font-poppins h-10">Essential tools for independent sellers.</p>
                <div class="my-6">
                    <span class="font-outfit font-bold text-5xl text-white">Free</span>
                </div>
                <ul class="space-y-4 mb-8 flex-1">
                    <li class="flex items-center gap-3 text-sm font-poppins text-white"><i class="fa-solid fa-check text-[#60A5FA]"></i> Up to 10 Listings</li>
                    <li class="flex items-center gap-3 text-sm font-poppins text-white"><i class="fa-solid fa-check text-[#60A5FA]"></i> Basic Analytics</li>
                    <li class="flex items-center gap-3 text-sm font-poppins text-white"><i class="fa-solid fa-check text-[#60A5FA]"></i> Standard Support</li>
                    <li class="flex items-center gap-3 text-sm font-poppins text-white/50"><i class="fa-solid fa-xmark"></i> No Featured Listings</li>
                </ul>
                <button class="w-full py-3 rounded-lg bg-white/10 text-white font-poppins font-semibold cursor-default border border-white/20">Active Plan</button>
            </div>

            <!-- Gold Plan -->
            <div class="glass-panel p-8 rounded-2xl flex flex-col hover:-translate-y-2 hover:shadow-xl transition-all duration-300" data-aos="fade-up" data-aos-delay="200">
                <h3 class="font-outfit font-bold text-xl text-[#1E3A5F] mb-2">Gold</h3>
                <p class="text-sm text-[#718096] font-poppins h-10">Perfect for growing agencies and top sellers.</p>
                <div class="my-6">
                    <span class="font-outfit font-bold text-4xl text-[#1E3A5F]">$99</span>
                    <span class="text-[#718096] font-poppins text-sm">/month</span>
                </div>
                <ul class="space-y-4 mb-8 flex-1">
                    <li class="flex items-center gap-3 text-sm font-poppins text-[#1E3A5F]"><i class="fa-solid fa-check text-[#D4AF37]"></i> Up to 50 Listings</li>
                    <li class="flex items-center gap-3 text-sm font-poppins text-[#1E3A5F]"><i class="fa-solid fa-check text-[#D4AF37]"></i> Advanced Analytics</li>
                    <li class="flex items-center gap-3 text-sm font-poppins text-[#1E3A5F]"><i class="fa-solid fa-check text-[#D4AF37]"></i> 5 Featured Listings/mo</li>
                    <li class="flex items-center gap-3 text-sm font-poppins text-[#1E3A5F]"><i class="fa-solid fa-check text-[#D4AF37]"></i> Priority 24/7 Support</li>
                </ul>
                <button class="w-full py-3 rounded-lg bg-[#1E3A5F] text-white font-poppins font-semibold hover:bg-[#2D4A8A] transition-colors" onclick="showToast('Contact us to upgrade to Gold.', 'success')">Upgrade Now</button>
            </div>

            <!-- Platinum Plan -->
            <div class="glass-panel p-8 rounded-2xl flex flex-col hover:-translate-y-2 hover:shadow-xl transition-all duration-300" data-aos="fade-up" data-aos-delay="300">
                <h3 class="font-outfit font-bold text-xl text-[#1E3A5F] mb-2">Platinum</h3>
                <p class="text-sm text-[#718096] font-poppins h-10">For large brokerages dominating the market.</p>
                <div class="my-6">
                    <span class="font-outfit font-bold text-4xl text-[#1E3A5F]">$249</span>
                    <span class="text-[#718096] font-poppins text-sm">/month</span>
                </div>
                <ul class="space-y-4 mb-8 flex-1">
                    <li class="flex items-center gap-3 text-sm font-poppins text-[#1E3A5F]"><i class="fa-solid fa-check text-purple-500"></i> Unlimited Listings</li>
                    <li class="flex items-center gap-3 text-sm font-poppins text-[#1E3A5F]"><i class="fa-solid fa-check text-purple-500"></i> Custom Reporting</li>
                    <li class="flex items-center gap-3 text-sm font-poppins text-[#1E3A5F]"><i class="fa-solid fa-check text-purple-500"></i> 20 Featured Spots/mo</li>
                    <li class="flex items-center gap-3 text-sm font-poppins text-[#1E3A5F]"><i class="fa-solid fa-check text-purple-500"></i> Dedicated Account Manager</li>
                </ul>
                <button class="w-full py-3 rounded-lg bg-[#2563EB] text-white font-poppins font-semibold hover:bg-[#1E3A5F] transition-colors shadow-lg shadow-[#2563EB]/30" onclick="showToast('Contact us to upgrade to Platinum.', 'success')">Upgrade Now</button>
            </div>
        </div>
    </div>

    <!-- Comparison Table & Benefits -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12 items-start">
        <div class="lg:col-span-8 glass-panel p-6 overflow-x-auto" data-aos="fade-right">
            <h2 class="font-outfit font-bold text-2xl text-[#1E3A5F] mb-6">Compare Features</h2>
            <table class="w-full text-left font-poppins text-sm whitespace-nowrap">
                <thead>
                    <tr class="border-b border-[#1E3A5F]/10">
                        <th class="py-4 px-4 text-[#718096] font-semibold w-1/3">Features</th>
                        <th class="py-4 px-4 text-[#2563EB] font-bold text-center bg-[#2563EB]/5 rounded-t-lg">Basic</th>
                        <th class="py-4 px-4 text-[#D4AF37] font-bold text-center">Gold</th>
                        <th class="py-4 px-4 text-purple-600 font-bold text-center">Platinum</th>
                    </tr>
                </thead>
                <tbody class="text-[#1E3A5F]">
                    <tr class="border-b border-gray-100 hover:bg-gray-50/50">
                        <td class="py-4 px-4 font-medium">Max Listings</td>
                        <td class="py-4 px-4 text-center bg-[#2563EB]/5 font-bold">10</td>
                        <td class="py-4 px-4 text-center">50</td>
                        <td class="py-4 px-4 text-center">Unlimited</td>
                    </tr>
                    <tr class="border-b border-gray-100 hover:bg-gray-50/50">
                        <td class="py-4 px-4 font-medium">Featured Properties</td>
                        <td class="py-4 px-4 text-center bg-[#2563EB]/5 text-gray-300"><i class="fa-solid fa-minus"></i></td>
                        <td class="py-4 px-4 text-center">5 / month</td>
                        <td class="py-4 px-4 text-center">20 / month</td>
                    </tr>
                    <tr class="border-b border-gray-100 hover:bg-gray-50/50">
                        <td class="py-4 px-4 font-medium">Lead Generation</td>
                        <td class="py-4 px-4 text-center bg-[#2563EB]/5 text-gray-300"><i class="fa-solid fa-minus"></i></td>
                        <td class="py-4 px-4 text-center"><i class="fa-solid fa-check text-green-500"></i></td>
                        <td class="py-4 px-4 text-center"><i class="fa-solid fa-check text-green-500"></i></td>
                    </tr>
                    <tr class="border-b border-gray-100 hover:bg-gray-50/50">
                        <td class="py-4 px-4 font-medium">Analytics Dashboard</td>
                        <td class="py-4 px-4 text-center bg-[#2563EB]/5 text-sm">Basic</td>
                        <td class="py-4 px-4 text-center">Advanced</td>
                        <td class="py-4 px-4 text-center">Custom Reports</td>
                    </tr>
                    <tr class="hover:bg-gray-50/50">
                        <td class="py-4 px-4 font-medium rounded-bl-lg">Support</td>
                        <td class="py-4 px-4 text-center bg-[#2563EB]/5 rounded-b-lg">Email Only</td>
                        <td class="py-4 px-4 text-center">24/7 Priority</td>
                        <td class="py-4 px-4 text-center rounded-br-lg">Dedicated Manager</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="lg:col-span-4 bg-white rounded-xl border border-[#1E3A5F]/10 p-6 shadow-sm" data-aos="fade-left">
            <h2 class="font-outfit font-bold text-xl text-[#1E3A5F] mb-6">Why Upgrade?</h2>
            <div class="space-y-6">
                <div class="flex gap-4">
                    <div class="w-10 h-10 rounded-full bg-[#2563EB]/10 flex items-center justify-center flex-shrink-0 text-[#2563EB]">
                        <i class="fa-solid fa-chart-line"></i>
                    </div>
                    <div>
                        <h4 class="font-outfit font-semibold text-[#1E3A5F] text-sm">More Visibility</h4>
                        <p class="text-xs font-poppins text-[#718096] mt-1">Featured properties get 4x more views and inquiries than standard listings.</p>
                    </div>
                </div>
                <div class="flex gap-4">
                    <div class="w-10 h-10 rounded-full bg-[#D4AF37]/10 flex items-center justify-center flex-shrink-0 text-[#D4AF37]">
                        <i class="fa-solid fa-headset"></i>
                    </div>
                    <div>
                        <h4 class="font-outfit font-semibold text-[#1E3A5F] text-sm">Priority Support</h4>
                        <p class="text-xs font-poppins text-[#718096] mt-1">Jump the queue. Get your issues resolved within 2 hours by our premium team.</p>
                    </div>
                </div>
                <div class="flex gap-4">
                    <div class="w-10 h-10 rounded-full bg-green-500/10 flex items-center justify-center flex-shrink-0 text-green-600">
                        <i class="fa-solid fa-users-viewfinder"></i>
                    </div>
                    <div>
                        <h4 class="font-outfit font-semibold text-[#1E3A5F] text-sm">Better Leads</h4>
                        <p class="text-xs font-poppins text-[#718096] mt-1">Access verified buyer leads before they are shown to basic tier members.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</main>

@section Scripts {
<script>
    AOS.init({ duration: 800, once: true, offset: 50 });
</script>
}
