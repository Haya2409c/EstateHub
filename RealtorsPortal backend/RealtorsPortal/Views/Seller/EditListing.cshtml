@model RealtorsPortal.Models.ViewModels.CreateListingViewModel
@{
    Layout = "_SellerLayout";
    ViewData["Title"] = "Edit Property";
    ViewData["PageHeading"] = "Edit Property";
    var propertyId = (int)ViewBag.PropertyId;
    var existingImages = ViewBag.ExistingImages as List<RealtorsPortal.Models.Entities.PropertyImage> ?? new();
    var amenities = Model.Amenities ?? new List<string>();
}

<main class="flex-1 p-6 max-w-4xl mx-auto w-full pb-24 lg:pb-12">

    <form asp-controller="Seller" asp-action="EditListing" asp-route-id="@propertyId"
          method="post" enctype="multipart/form-data" class="space-y-6">
        @Html.AntiForgeryToken()

        <!-- Section 1: Basic Information -->
        <div class="glass-panel p-6 sm:p-8 mb-6">
            <h2 class="section-heading">Basic Information</h2>
            <div class="space-y-4">
                <div>
                    <label>Property Title <span class="required">*</span></label>
                    <input type="text" name="Title" value="@Model.Title" required>
                </div>
                <div>
                    <label>Description <span class="required">*</span></label>
                    <textarea name="Description" rows="5" required>@Model.Description</textarea>
                </div>
                <div>
                    <label>Property Type <span class="required">*</span></label>
                    <select name="PropertyType" required>
                        <option value="house"      selected="@(Model.PropertyType == "house")">House</option>
                        <option value="apartment"  selected="@(Model.PropertyType == "apartment")">Apartment</option>
                        <option value="plot"       selected="@(Model.PropertyType == "plot")">Plot</option>
                        <option value="commercial" selected="@(Model.PropertyType == "commercial")">Commercial Space</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Section 2: Property Status -->
        <div class="glass-panel p-6 sm:p-8 mb-6">
            <h2 class="section-heading">Property Status</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <label class="cursor-pointer">
                    <input type="radio" name="Status" value="buy" class="peer hidden" @(Model.Status == "buy" ? "checked" : "")>
                    <div class="border-2 border-transparent peer-checked:border-[#1E3A5F] peer-checked:bg-[#1E3A5F]/5 rounded-xl p-4 text-center transition-all bg-white shadow-sm hover:shadow-md">
                        <i class="fa-solid fa-tag text-2xl text-[#2563EB] mb-2"></i>
                        <div class="font-outfit font-semibold text-[#1E3A5F]">Buy</div>
                    </div>
                </label>
                <label class="cursor-pointer">
                    <input type="radio" name="Status" value="rent" class="peer hidden" @(Model.Status == "rent" ? "checked" : "")>
                    <div class="border-2 border-transparent peer-checked:border-[#1E3A5F] peer-checked:bg-[#1E3A5F]/5 rounded-xl p-4 text-center transition-all bg-white shadow-sm hover:shadow-md">
                        <i class="fa-solid fa-key text-2xl text-[#2563EB] mb-2"></i>
                        <div class="font-outfit font-semibold text-[#1E3A5F]">Rent</div>
                    </div>
                </label>
                <label class="cursor-pointer">
                    <input type="radio" name="Status" value="sell" class="peer hidden" @(Model.Status == "sell" ? "checked" : "")>
                    <div class="border-2 border-transparent peer-checked:border-[#1E3A5F] peer-checked:bg-[#1E3A5F]/5 rounded-xl p-4 text-center transition-all bg-white shadow-sm hover:shadow-md">
                        <i class="fa-solid fa-briefcase text-2xl text-[#2563EB] mb-2"></i>
                        <div class="font-outfit font-semibold text-[#1E3A5F]">Sell</div>
                    </div>
                </label>
            </div>
        </div>

        <!-- Section 3: Location -->
        <div class="glass-panel p-6 sm:p-8 mb-6">
            <h2 class="section-heading">Location</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                    <label>Country</label>
                    <select name="Country">
                        <option value="pk" selected>Pakistan</option>
                    </select>
                </div>
                <div>
                    <label>Region</label>
                    <select name="Region">
                        <option value="sindh">Sindh</option>
                        <option value="punjab">Punjab</option>
                        <option value="kpk">KPK</option>
                        <option value="balochistan">Balochistan</option>
                    </select>
                </div>
                <div>
                    <label>City</label>
                    <select name="City">
                        <option value="karachi">Karachi</option>
                        <option value="lahore">Lahore</option>
                        <option value="islamabad">Islamabad</option>
                        <option value="peshawar">Peshawar</option>
                        <option value="quetta">Quetta</option>
                    </select>
                </div>
            </div>
            <div>
                <label>Full Address <span class="required">*</span></label>
                <input type="text" name="Address" value="@Model.Address" required>
            </div>
        </div>

        <!-- Section 4: Property Details -->
        <div class="glass-panel p-6 sm:p-8 mb-6">
            <h2 class="section-heading">Property Details</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div>
                    <label>Price (PKR) <span class="required">*</span></label>
                    <input type="number" name="Price" value="@Model.Price" required>
                </div>
                <div>
                    <label>Bedrooms</label>
                    <input type="number" name="Bedrooms" value="@Model.Bedrooms">
                </div>
                <div>
                    <label>Bathrooms</label>
                    <input type="number" name="Bathrooms" value="@Model.Bathrooms">
                </div>
                <div>
                    <label>Area (sqft)</label>
                    <input type="number" name="AreaSqft" value="@Model.AreaSqft">
                </div>
            </div>
        </div>

        <!-- Section 5: Amenities -->
        <div class="glass-panel p-6 sm:p-8 mb-6">
            <h2 class="section-heading">Amenities</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                @foreach (var item in new[] { ("wifi","WiFi"), ("gym","Gym"), ("pool","Swimming Pool"), ("security","Security"), ("elevator","Elevator"), ("garden","Garden") })
                {
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="checkbox" name="Amenities" value="@item.Item1" class="custom-checkbox" @(amenities.Contains(item.Item1) ? "checked" : "")>
                        <span class="font-poppins text-sm text-[#1E3A5F] group-hover:text-[#2563EB] transition-colors">@item.Item2</span>
                    </label>
                }
            </div>
        </div>

        <!-- Section 6: Add New Images -->
        <div class="glass-panel p-6 sm:p-8 mb-8">
            <h2 class="section-heading">Add New Images</h2>
            <div class="border-2 border-dashed border-[#1E3A5F]/30 hover:border-[#1E3A5F] bg-white rounded-2xl p-8 text-center transition-colors cursor-pointer"
                 onclick="document.getElementById('fileInput').click()">
                <div class="w-16 h-16 bg-[#F4F6F9] rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fa-solid fa-cloud-arrow-up text-2xl text-[#2563EB]"></i>
                </div>
                <h3 class="font-outfit font-semibold text-[#1E3A5F] mb-1">Click to browse or drag & drop</h3>
                <p class="font-poppins text-sm text-[#718096] mb-2">JPG, PNG, WEBP — max 5MB each</p>
                <input type="file" id="fileInput" name="Images" class="hidden" multiple accept="image/*">
            </div>
            <div class="flex gap-4 mt-4 overflow-x-auto pb-2" id="thumbnailContainer"></div>
        </div>

        <!-- Submit -->
        <div class="fixed bottom-0 left-0 right-0 lg:static bg-white/95 backdrop-blur-md lg:bg-transparent p-4 lg:p-0 border-t lg:border-none border-white/20 z-20 flex justify-end gap-4 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)] lg:shadow-none">
            <a asp-controller="Seller" asp-action="MyListings" class="btn-outline-navy w-1/2 lg:w-auto">Cancel</a>
            <button type="submit" class="btn-gold w-1/2 lg:w-auto">Save Changes <i class="fa-solid fa-check ml-1"></i></button>
        </div>

    </form>

    @* Existing images panel — OUTSIDE main form to avoid nested forms *@
    @if (existingImages.Any())
    {
        <div class="glass-panel p-6 sm:p-8 mt-6">
            <h2 class="section-heading">Current Images
                <span class="text-xs font-normal text-[#718096] bg-[#F4F6F9] px-2 py-1 rounded ml-2">hover to delete</span>
            </h2>
            <div class="flex flex-wrap gap-4">
                @foreach (var img in existingImages)
                {
                    <div class="w-28 h-28 flex-shrink-0 rounded-xl overflow-hidden relative group shadow-sm">
                        <img src="@img.Url" class="w-full h-full object-cover">
                        @if (img.IsPrimary)
                        {
                            <span class="absolute top-1 left-1 bg-[#D4AF37] text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full">Primary</span>
                        }
                        <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity">
                            <form asp-controller="Seller" asp-action="DeleteImage" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="imageId" value="@img.Id">
                                <input type="hidden" name="listingId" value="@propertyId">
                                <button type="submit" class="w-10 h-10 rounded-full bg-red-500 hover:bg-red-600 text-white flex items-center justify-center transition-colors" title="Delete">
                                    <i class="fa-solid fa-trash text-sm"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</main>

@section Scripts {
<script>
    document.getElementById('fileInput').addEventListener('change', function(e) {
        const container = document.getElementById('thumbnailContainer');
        Array.from(this.files).forEach(file => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const div = document.createElement('div');
                div.className = 'w-24 h-24 flex-shrink-0 rounded-lg overflow-hidden relative group';
                div.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity cursor-pointer">
                        <i class="fa-solid fa-times text-white text-xl"></i>
                    </div>`;
                div.querySelector('.fa-times').addEventListener('click', ev => { ev.stopPropagation(); div.remove(); });
                container.appendChild(div);
            };
            reader.readAsDataURL(file);
        });
    });
</script>
}
