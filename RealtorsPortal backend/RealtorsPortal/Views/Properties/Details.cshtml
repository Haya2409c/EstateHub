@model RealtorsPortal.Models.ViewModels.Properties.PropertyDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
    var status = ViewBag.Status as string;
    var amenities = ViewBag.Amenities as List<string> ?? new List<string>();
    var primaryImage = Model.ImageGallery.FirstOrDefault(i => i.IsPrimary)?.Url
        ?? Model.ImageGallery.OrderBy(i => i.SortOrder).FirstOrDefault()?.Url
        ?? "/assets/images/new-property-1.jpg";
    var statusLabel = status switch { "buy" => "For Buy", "rent" => "For Rent", "sell" => "For Sale", _ => "Listed" };
    var statusColor = status switch { "buy" => "bg-blue-500", "rent" => "bg-green-500", _ => "bg-[#D4AF37]" };
    var amenityLabels = new Dictionary<string, string> {
        {"wifi","WiFi"}, {"gym","Gym"}, {"pool","Swimming Pool"},
        {"security","Security"}, {"elevator","Elevator"}, {"garden","Garden"}
    };
}

@if (TempData["Success"] != null)
{
    <div class="fixed top-24 right-6 z-50 bg-green-500 text-white px-6 py-3 rounded-xl shadow-lg font-poppins text-sm">
        <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
    </div>
}

<section class="pt-32 pb-20 bg-[#F4F6F9] min-h-screen">
    <div class="container mx-auto px-4 md:px-6 max-w-6xl">

        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm font-poppins text-[#718096] mb-6">
            <a href="/" class="hover:text-[#2563EB] transition-colors">Home</a>
            <i class="fas fa-chevron-right text-xs"></i>
            <a asp-controller="Properties" asp-action="Index" class="hover:text-[#2563EB] transition-colors">Properties</a>
            <i class="fas fa-chevron-right text-xs"></i>
            <span class="text-[#1E3A5F] font-medium line-clamp-1">@Model.Title</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <!-- Left / Main Column -->
            <div class="lg:col-span-2 space-y-6">

                <!-- Image Gallery -->
                <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
                    <div class="relative">
                        <img id="mainImage" src="@primaryImage" alt="@Model.Title"
                             class="w-full h-72 md:h-96 object-cover"
                             onerror="this.src='/assets/images/new-property-1.jpg'">
                        <span class="absolute top-4 left-4 @statusColor text-white text-sm font-bold px-4 py-1.5 rounded-full">@statusLabel</span>
                        @if (Model.PropertyType != null)
                        {
                            <span class="absolute top-4 right-4 bg-white/90 text-[#1E3A5F] text-sm font-semibold px-4 py-1.5 rounded-full">@Model.PropertyType</span>
                        }
                    </div>
                    @if (Model.ImageGallery.Count > 1)
                    {
                        <div class="flex gap-2 p-4 overflow-x-auto">
                            @foreach (var img in Model.ImageGallery)
                            {
                                <button onclick="document.getElementById('mainImage').src='@img.Url'"
                                        class="flex-shrink-0 w-20 h-16 rounded-lg overflow-hidden border-2 @(img.IsPrimary ? "border-[#D4AF37]" : "border-transparent") hover:border-[#2563EB] transition-colors">
                                    <img src="@img.Url" class="w-full h-full object-cover"
                                         onerror="this.src='/assets/images/new-property-1.jpg'">
                                </button>
                            }
                        </div>
                    }
                </div>

                <!-- Title & Price -->
                <div class="bg-white rounded-2xl shadow-sm p-6">
                    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                        <div>
                            <h1 class="font-outfit font-bold text-2xl md:text-3xl text-[#1E3A5F] mb-2">@Model.Title</h1>
                            <p class="text-[#718096] flex items-center gap-2">
                                <i class="fas fa-map-marker-alt text-[#D4AF37]"></i> @Model.Address
                            </p>
                        </div>
                        <div class="text-right flex-shrink-0">
                            <p class="text-3xl font-bold text-[#D4AF37]">PKR @Model.Price.ToString("N0")</p>
                            <p class="text-sm text-[#718096]">Listed @Model.ListedDate.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>

                <!-- Key Stats -->
                <div class="bg-white rounded-2xl shadow-sm p-6">
                    <h2 class="font-outfit font-bold text-xl text-[#1E3A5F] mb-4">Property Details</h2>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                        @if (Model.Bedrooms.HasValue)
                        {
                            <div class="flex flex-col items-center bg-[#F4F6F9] rounded-xl p-4 text-center">
                                <i class="fas fa-bed text-2xl text-[#2563EB] mb-2"></i>
                                <span class="font-bold text-[#1E3A5F] text-xl">@Model.Bedrooms</span>
                                <span class="text-xs text-[#718096] uppercase tracking-wider mt-1">Bedrooms</span>
                            </div>
                        }
                        @if (Model.Bathrooms.HasValue)
                        {
                            <div class="flex flex-col items-center bg-[#F4F6F9] rounded-xl p-4 text-center">
                                <i class="fas fa-bath text-2xl text-[#2563EB] mb-2"></i>
                                <span class="font-bold text-[#1E3A5F] text-xl">@Model.Bathrooms</span>
                                <span class="text-xs text-[#718096] uppercase tracking-wider mt-1">Bathrooms</span>
                            </div>
                        }
                        @if (Model.AreaSqft.HasValue)
                        {
                            <div class="flex flex-col items-center bg-[#F4F6F9] rounded-xl p-4 text-center">
                                <i class="fas fa-ruler-combined text-2xl text-[#2563EB] mb-2"></i>
                                <span class="font-bold text-[#1E3A5F] text-xl">@Model.AreaSqft</span>
                                <span class="text-xs text-[#718096] uppercase tracking-wider mt-1">Sqft</span>
                            </div>
                        }
                        <div class="flex flex-col items-center bg-[#F4F6F9] rounded-xl p-4 text-center">
                            <i class="fas fa-home text-2xl text-[#2563EB] mb-2"></i>
                            <span class="font-bold text-[#1E3A5F] text-sm">@(Model.PropertyType ?? "—")</span>
                            <span class="text-xs text-[#718096] uppercase tracking-wider mt-1">Type</span>
                        </div>
                    </div>
                </div>

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="bg-white rounded-2xl shadow-sm p-6">
                        <h2 class="font-outfit font-bold text-xl text-[#1E3A5F] mb-4">Description</h2>
                        <p class="font-poppins text-[#4a5568] leading-relaxed">@Model.Description</p>
                    </div>
                }

                <!-- Amenities -->
                @if (amenities.Any())
                {
                    <div class="bg-white rounded-2xl shadow-sm p-6">
                        <h2 class="font-outfit font-bold text-xl text-[#1E3A5F] mb-4">Amenities & Features</h2>
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                            @foreach (var a in amenities)
                            {
                                var label = amenityLabels.GetValueOrDefault(a, a);
                                var icon = a switch {
                                    "wifi" => "fa-wifi", "gym" => "fa-dumbbell", "pool" => "fa-swimmer",
                                    "security" => "fa-shield-alt", "elevator" => "fa-sort", "garden" => "fa-leaf", _ => "fa-check"
                                };
                                <div class="flex items-center gap-3 bg-[#F4F6F9] rounded-xl px-4 py-3">
                                    <i class="fas @icon text-[#2563EB]"></i>
                                    <span class="font-poppins text-sm text-[#1E3A5F] font-medium">@label</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Right / Sidebar -->
            <div class="space-y-6">

                <!-- Quick Info Card -->
                <div class="bg-white rounded-2xl shadow-sm p-6 border border-gray-100">
                    <h3 class="font-outfit font-bold text-lg text-[#1E3A5F] mb-4 border-b border-gray-100 pb-3">Quick Info</h3>
                    <dl class="space-y-3 font-poppins text-sm">
                        <div class="flex justify-between">
                            <dt class="text-[#718096]">Property ID</dt>
                            <dd class="font-semibold text-[#1E3A5F]">#@Model.Id</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-[#718096]">Status</dt>
                            <dd><span class="@statusColor text-white text-xs font-bold px-2 py-0.5 rounded-full">@statusLabel</span></dd>
                        </div>
                        @if (Model.PropertyType != null)
                        {
                            <div class="flex justify-between">
                                <dt class="text-[#718096]">Type</dt>
                                <dd class="font-semibold text-[#1E3A5F]">@Model.PropertyType</dd>
                            </div>
                        }
                        @if (Model.Bedrooms.HasValue)
                        {
                            <div class="flex justify-between">
                                <dt class="text-[#718096]">Bedrooms</dt>
                                <dd class="font-semibold text-[#1E3A5F]">@Model.Bedrooms</dd>
                            </div>
                        }
                        @if (Model.Bathrooms.HasValue)
                        {
                            <div class="flex justify-between">
                                <dt class="text-[#718096]">Bathrooms</dt>
                                <dd class="font-semibold text-[#1E3A5F]">@Model.Bathrooms</dd>
                            </div>
                        }
                        @if (Model.AreaSqft.HasValue)
                        {
                            <div class="flex justify-between">
                                <dt class="text-[#718096]">Area</dt>
                                <dd class="font-semibold text-[#1E3A5F]">@Model.AreaSqft sqft</dd>
                            </div>
                        }
                        <div class="flex justify-between">
                            <dt class="text-[#718096]">Listed</dt>
                            <dd class="font-semibold text-[#1E3A5F]">@Model.ListedDate.ToString("MMM dd, yyyy")</dd>
                        </div>
                    </dl>
                </div>

                <!-- Enquiry Form -->
                <div class="bg-gradient-to-br from-[#1E3A5F] to-[#2D4A8A] rounded-2xl shadow-sm p-6 text-white">
                    <h3 class="font-outfit font-bold text-lg mb-4">Enquire About This Property</h3>
                    <form asp-controller="Properties" asp-action="ContactAgent" method="post" class="space-y-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PropertyId" value="@Model.Id">
                        <input type="text" name="FullName" placeholder="Your Full Name" required
                               class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-sm text-white placeholder-white/60 focus:outline-none focus:border-[#D4AF37] transition-colors">
                        <input type="email" name="Email" placeholder="Your Email Address" required
                               class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-sm text-white placeholder-white/60 focus:outline-none focus:border-[#D4AF37] transition-colors">
                        <input type="tel" name="Phone" placeholder="Phone Number (Optional)"
                               class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-sm text-white placeholder-white/60 focus:outline-none focus:border-[#D4AF37] transition-colors">
                        <textarea name="Message" rows="4"
                                  placeholder="I'm interested in this property and would like more information..."
                                  class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-sm text-white placeholder-white/60 focus:outline-none focus:border-[#D4AF37] transition-colors resize-none"></textarea>
                        <button type="submit"
                                class="w-full bg-[#D4AF37] hover:bg-yellow-500 text-white font-bold py-3 rounded-xl transition-colors text-sm tracking-wide">
                            <i class="fas fa-paper-plane mr-2"></i> Send Enquiry
                        </button>
                    </form>
                </div>

                <!-- Share / Back -->
                <div class="flex gap-3">
                    <a asp-controller="Properties" asp-action="Index"
                       class="flex-1 py-3 rounded-xl border border-gray-200 text-[#1E3A5F] text-sm font-semibold text-center hover:border-[#1E3A5F] transition-colors">
                        <i class="fas fa-arrow-left mr-1"></i> Back to Listings
                    </a>
                    <button onclick="navigator.share ? navigator.share({title:'@Model.Title',url:window.location.href}) : navigator.clipboard.writeText(window.location.href)"
                            class="flex-1 py-3 rounded-xl border border-gray-200 text-[#1E3A5F] text-sm font-semibold hover:border-[#D4AF37] hover:text-[#D4AF37] transition-colors">
                        <i class="fas fa-share-alt mr-1"></i> Share
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
