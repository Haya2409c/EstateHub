@model RealtorsPortal.Models.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Login";
}
<!-- Login Section -->
    <main class="flex-grow flex items-center justify-center pt-32 pb-20 relative bg-deep">
        <!-- Background Image -->
        <div class="absolute inset-0 opacity-20">
            <img src="https://images.unsplash.com/photo-1600607687939-ce8a6d9de4f1?auto=format&fit=crop&w=1920&q=80" class="w-full h-full object-cover">
        </div>
        <div class="absolute inset-0 bg-[#0F2040]/60"></div>

        <!-- Login Card -->
        <div id="login-card" class="p-10 md:p-14 rounded-3xl w-full max-w-lg relative z-10 mx-6" data-aos="zoom-in">
            <div class="text-center mb-10">
                <div class="w-16 h-16 bg-gold rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-[0_0_30px_rgba(212,175,55,0.3)]">
                    <i class="fas fa-user text-white text-3xl"></i>
                </div>
                <h1 class="text-3xl font-bold mb-2">Welcome Back</h1>
                <p class="text-[#4a5568] text-sm">Sign in to access your exclusive portfolio</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="mb-4 text-red-400 text-sm text-center"></div>

            <form asp-action="Login" asp-controller="Account" method="POST">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <!-- Email Field -->
                <div class="mb-6">
                    <label asp-for="Email" class="block text-xs font-bold text-[#4a5568] uppercase tracking-widest mb-3">Email Address</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="far fa-envelope text-gray-500"></i>
                        </div>
                        <input asp-for="Email" type="email" placeholder="Enter your email" class="w-full bg-white border border-gray-200 rounded-xl pl-12 pr-4 py-4 text-sm focus:border-navy outline-none text-gray-800 placeholder-gray-400 transition-colors">
                    </div>
                    <span asp-validation-for="Email" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <!-- Password Field -->
                <div class="mb-6">
                    <label asp-for="Password" class="block text-xs font-bold text-[#4a5568] uppercase tracking-widest mb-3">Password</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-gray-500"></i>
                        </div>
                        <input asp-for="Password" type="password" placeholder="Enter your password" class="w-full bg-white border border-gray-200 rounded-xl pl-12 pr-4 py-4 text-sm focus:border-navy outline-none text-gray-800 placeholder-gray-400 transition-colors">
                    </div>
                    <span asp-validation-for="Password" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <!-- Options -->
                <div class="flex items-center justify-between mb-8">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input asp-for="RememberMe" type="checkbox" class="w-4 h-4 rounded bg-white border-gray-200 text-gold focus:ring-gold accent-gold">
                        <span class="text-sm text-[#4a5568] group-hover:text-white transition-colors">Remember me</span>
                    </label>
                    <a href="#" class="text-sm text-gold hover:text-white transition-colors">Forgot Password?</a>
                </div>

                <!-- Login Button -->
                <button type="submit" class="w-full btn-gold !py-4 text-base font-bold shadow-[0_10px_30px_rgba(212,175,55,0.3)] hover:shadow-[0_10px_40px_rgba(212,175,55,0.5)]">
                    Sign In to Account
                </button>
            </form>

            <div class="mt-8 text-center border-t border-gray-200 pt-8">
                <p class="text-sm text-[#4a5568]">Don't have an account? <a asp-controller="Account" asp-action="Signup" class="text-gold font-bold hover:text-white transition-colors ml-1 border-b border-gold pb-0.5">Register Now</a></p>
            </div>

            <!-- Hidden admin access — visible only with ?admin=true -->
            <div id="admin-access-wrap" class="mt-6 text-center hidden">
                <a href="/admin" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gold/30 text-gold/70 hover:text-gold hover:border-gold/60 text-xs font-medium transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
                    Admin Portal
                </a>
            </div>

            <!-- Tiny gear icon always visible at bottom — click or ?admin=true to reveal button -->
            <div class="mt-3 text-center">
                <button id="admin-hint-btn" title="Admin Access" class="text-gray-500/20 hover:text-gray-500/50 transition-colors text-xs select-none">⚙</button>
            </div>
        </div>
    </main>

    <script>
        (function () {
            var wrap   = document.getElementById('admin-access-wrap');
            var hint   = document.getElementById('admin-hint-btn');
            var clicks = 0;
            // Show via ?admin=true param
            if (new URLSearchParams(window.location.search).get('admin') === 'true') {
                wrap.classList.remove('hidden');
            }
            // Show after clicking gear icon 3 times
            hint.addEventListener('click', function () {
                if (++clicks >= 3) { wrap.classList.remove('hidden'); hint.classList.add('hidden'); }
            });
        })();
    </script>

    <!-- Footer -->

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
