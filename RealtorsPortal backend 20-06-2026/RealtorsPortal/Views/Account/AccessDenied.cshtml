@{
    ViewData["Title"] = "Access Denied";
}

<section class="min-h-screen bg-[#F4F6F9] flex items-center justify-center px-4 pt-24 pb-12">
    <div class="max-w-md w-full text-center">

        <div class="w-24 h-24 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-lock text-red-500 text-4xl"></i>
        </div>

        <h1 class="font-outfit font-bold text-3xl text-[#1E3A5F] mb-3">Access Denied</h1>
        <p class="font-poppins text-[#718096] mb-8">
            You don't have permission to view this page.
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span>This area is restricted to a different account type.</span>
            }
            else
            {
                <span>Please log in to continue.</span>
            }
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (User.IsInRole("Seller"))
                {
                    <a asp-controller="Seller" asp-action="Index"
                       class="px-6 py-3 bg-[#1E3A5F] text-white rounded-xl font-semibold text-sm hover:bg-[#2D4A8A] transition-colors">
                        <i class="fas fa-th-large mr-2"></i>Go to My Dashboard
                    </a>
                }
                else if (User.IsInRole("Agent"))
                {
                    <a asp-controller="Agent" asp-action="Index"
                       class="px-6 py-3 bg-[#1E3A5F] text-white rounded-xl font-semibold text-sm hover:bg-[#2D4A8A] transition-colors">
                        <i class="fas fa-th-large mr-2"></i>Go to My Dashboard
                    </a>
                }
                else if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index"
                       class="px-6 py-3 bg-[#1E3A5F] text-white rounded-xl font-semibold text-sm hover:bg-[#2D4A8A] transition-colors">
                        <i class="fas fa-th-large mr-2"></i>Go to Admin Panel
                    </a>
                }

                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full sm:w-auto px-6 py-3 border border-gray-300 text-[#1E3A5F] rounded-xl font-semibold text-sm hover:border-[#1E3A5F] transition-colors">
                        <i class="fas fa-sign-out-alt mr-2"></i>Switch Account
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                   class="px-6 py-3 bg-[#1E3A5F] text-white rounded-xl font-semibold text-sm hover:bg-[#2D4A8A] transition-colors">
                    <i class="fas fa-sign-in-alt mr-2"></i>Log In
                </a>
            }

            <a asp-controller="Home" asp-action="Index"
               class="px-6 py-3 border border-gray-300 text-[#1E3A5F] rounded-xl font-semibold text-sm hover:border-[#1E3A5F] transition-colors">
                <i class="fas fa-home mr-2"></i>Back to Home
            </a>
        </div>
    </div>
</section>
