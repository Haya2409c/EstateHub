@{
    ViewData["Title"] = "Wishlist";
}
<!-- Header -->
    <section class="pt-32 pb-12 bg-deep border-b border-gray-200">
        <div class="container mx-auto px-6">
            <h1 class="text-[#1E3A5F] text-4xl font-bold mb-2">My <span class="text-gold">Wishlist</span></h1>
            <p id="wishlist-count" class="text-gray-500 uppercase tracking-widest text-xs font-bold">0 Properties Saved</p>
        </div>
    </section>

    <!-- Wishlist Items -->
    <section class="py-20 container mx-auto px-6">
        <div id="wishlist-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
            <!-- Properties will be injected here by script.js -->
        </div>
    </section>

    <!-- Footer -->
