@using RealtorsPortal.Models.Entities
@{
    ViewData["Title"] = "Listings";
    Layout = "_AdminLayout";
    var properties    = (List<Property>)ViewBag.Properties;
    var currentStatus = (string)ViewBag.Status;
    var currentPage   = (int)ViewBag.CurrentPage;
    var totalPages    = (int)ViewBag.TotalPages;
    var pendingCount  = (int)ViewBag.PendingCount;
    var activeCount   = (int)ViewBag.ActiveCount;
    var rejectedCount = (int)ViewBag.RejectedCount;
    ViewBag.PendingBadge = pendingCount;
}

@if (TempData["Success"] != null)
{
    <div class="mb-6 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm">
        @TempData["Success"]
    </div>
}

<!-- Stats -->
<div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-5 text-center">
        <p class="text-3xl font-bold text-yellow-600">@pendingCount</p>
        <p class="text-sm text-yellow-700 mt-1 font-medium">Pending Review</p>
    </div>
    <div class="bg-green-50 border border-green-200 rounded-xl p-5 text-center">
        <p class="text-3xl font-bold text-green-600">@activeCount</p>
        <p class="text-sm text-green-700 mt-1 font-medium">Active / Live</p>
    </div>
    <div class="bg-red-50 border border-red-200 rounded-xl p-5 text-center">
        <p class="text-3xl font-bold text-red-600">@rejectedCount</p>
        <p class="text-sm text-red-700 mt-1 font-medium">Rejected</p>
    </div>
</div>

<!-- Filter Tabs -->
<div class="flex gap-2 mb-6">
    @foreach (var tab in new[] { ("all","All"), ("Pending","Pending"), ("Active","Active"), ("Rejected","Rejected") })
    {
        var isActive = currentStatus == tab.Item1;
        <a href="@Url.Action("Listings", "Admin", new { status = tab.Item1, page = 1 })"
           class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(isActive ? "bg-[#0F2040] text-white" : "bg-white text-gray-600 hover:bg-gray-50 border border-gray-200")">
            @tab.Item2
        </a>
    }
</div>

<!-- Table -->
<div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-200">
    @if (!properties.Any())
    {
        <div class="text-center py-16 text-gray-400">
            <i class="fas fa-house text-5xl opacity-20 mb-3 block"></i>
            <p class="text-sm">No listings found.</p>
        </div>
    }
    else
    {
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Property</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Price</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Listed</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="text-right px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var p in properties)
                {
                    var thumb = p.Images.FirstOrDefault(i => i.IsPrimary)?.Url
                             ?? p.Images.OrderBy(i => i.SortOrder).FirstOrDefault()?.Url
                             ?? "/assets/images/new-property-1.jpg";
                    var badgeClass = p.ApprovalStatus switch
                    {
                        "Active"   => "bg-green-100 text-green-700",
                        "Rejected" => "bg-red-100 text-red-700",
                        _          => "bg-yellow-100 text-yellow-700"
                    };
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <img src="@thumb" alt="@p.Title"
                                     class="w-14 h-10 object-cover rounded-lg bg-gray-100 flex-shrink-0"
                                     onerror="this.src='/assets/images/new-property-1.jpg'">
                                <div>
                                    <p class="font-medium text-gray-800 line-clamp-1">@p.Title</p>
                                    <p class="text-xs text-gray-400 mt-0.5">@(p.Address ?? "—")</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-4 text-gray-600">@(p.Category?.Name ?? p.PropertyType ?? "—")</td>
                        <td class="px-4 py-4 font-medium text-gray-800">PKR @p.Price.ToString("N0")</td>
                        <td class="px-4 py-4 text-gray-500">@p.ListedDate.ToString("dd MMM yyyy")</td>
                        <td class="px-4 py-4">
                            <span class="px-2.5 py-1 rounded-full text-xs font-semibold @badgeClass">@p.ApprovalStatus</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center justify-end gap-2">
                                @if (p.ApprovalStatus != "Active")
                                {
                                    <form asp-action="ApproveListing" asp-controller="Admin" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <input type="hidden" name="returnStatus" value="@currentStatus" />
                                        <button type="submit" class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-semibold rounded-lg transition-colors">Approve</button>
                                    </form>
                                }
                                @if (p.ApprovalStatus != "Rejected")
                                {
                                    <form asp-action="RejectListing" asp-controller="Admin" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <input type="hidden" name="returnStatus" value="@currentStatus" />
                                        <button type="submit" class="px-3 py-1.5 bg-red-100 hover:bg-red-200 text-red-700 text-xs font-semibold rounded-lg transition-colors">Reject</button>
                                    </form>
                                }
                                <a href="@Url.Action("Details","Properties", new { id = p.Id })" target="_blank"
                                   class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-semibold rounded-lg transition-colors">View</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (totalPages > 1)
        {
            <div class="flex items-center justify-center gap-2 p-4 border-t border-gray-100">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a href="@Url.Action("Listings","Admin", new { status = currentStatus, page = i })"
                       class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-medium transition-colors
                              @(i == currentPage ? "bg-[#0F2040] text-white" : "bg-gray-100 hover:bg-gray-200 text-gray-600")">@i</a>
                }
            </div>
        }
    }
</div>
