@{
    ViewData["Title"] = "About Us";
}
<!-- Page Header -->
    <section class="pt-32 pb-20 relative overflow-hidden h-[60vh] flex items-center">
        <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=1920&q=80" class="absolute top-0 left-0 w-full h-full object-cover opacity-30">
        <div class="container mx-auto px-6 text-center relative z-10">
            <span class="text-[#1E3A5F] uppercase tracking-[0.3em] text-sm font-semibold mb-4 block" data-aos="fade-up">Our Legacy</span>
            <h1 class="text-5xl md:text-8xl font-bold mb-6 text-gray-800" data-aos="fade-up" data-aos-delay="100">Redefining <span class="text-[#1E3A5F] italic font-normal">Luxury</span></h1>
            <p class="text-gray-700 max-w-2xl mx-auto text-lg" data-aos="fade-up" data-aos-delay="200">Established in 1995, EstateHub has been the premier portal for the world's most extraordinary residences.</p>
        </div>
    </section>

    <!-- Core Values -->
    <section class="py-20 container mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div data-aos="fade-right">
                <h2 class="text-4xl font-bold mb-8 text-gray-800">Guided by <span class="text-[#1E3A5F]">Excellence</span></h2>
                <p class="text-gray-600 text-lg mb-8 leading-relaxed">
                    At EstateHub, we believe that luxury is not just a price point—it's an experience. Our mission is to connect the world's most discerning buyers with architectural masterpieces that embody their unique vision of high-end living.
                </p>
                <div class="space-y-6">
                    <div class="flex gap-6">
                        <div class="w-14 h-14 bg-[#1E3A5F]/10 rounded-2xl flex items-center justify-center shrink-0"><i class="fas fa-gem text-[#1E3A5F] text-2xl"></i></div>
                        <div>
                            <h4 class="font-bold text-xl mb-1 text-gray-800">Uncompromising Quality</h4>
                            <p class="text-gray-500">We only list properties that meet our rigorous standards of architectural and design excellence.</p>
                        </div>
                    </div>
                    <div class="flex gap-6">
                        <div class="w-14 h-14 bg-[#1E3A5F]/10 rounded-2xl flex items-center justify-center shrink-0"><i class="fas fa-handshake text-[#1E3A5F] text-2xl"></i></div>
                        <div>
                            <h4 class="font-bold text-xl mb-1 text-gray-800">Absolute Discretion</h4>
                            <p class="text-gray-500">Privacy is the ultimate luxury. We handle every transaction with the highest level of confidentiality.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-6" data-aos="fade-left">
                <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=1200&q=80" class="rounded-3xl h-80 w-full object-cover mt-12">
                <img src="https://images.unsplash.com/photo-1600566753376-12c8ab7fb75b?auto=format&fit=crop&w=1200&q=80" class="rounded-3xl h-80 w-full object-cover">
            </div>
        </div>
    </section>

    <!-- Team Members -->
    <section class="py-20 bg-white border-t border-gray-200">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16" data-aos="fade-up">
                <span class="text-[#1E3A5F] uppercase tracking-[0.3em] text-sm font-semibold mb-2 block">Our Leaders</span>
                <h2 class="text-4xl font-bold text-gray-800">Meet The <span class="text-[#1E3A5F]">Team</span></h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div class="text-center" data-aos="fade-up" data-aos-delay="100">
                    <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&w=300&q=80" class="w-48 h-48 rounded-full object-cover mx-auto mb-6 border-4 border-[#1E3A5F]/20 grayscale hover:grayscale-0 transition-all">
                    <h4 class="text-xl font-bold text-gray-800">Alexander Sterling</h4>
                    <p style="color:#1E3A5F" class="text-sm font-bold uppercase tracking-widest mt-1">Founder & CEO</p>
                </div>
                <div class="text-center" data-aos="fade-up" data-aos-delay="200">
                    <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=300&q=80" class="w-48 h-48 rounded-full object-cover mx-auto mb-6 border-4 border-[#1E3A5F]/20 grayscale hover:grayscale-0 transition-all">
                    <h4 class="text-xl font-bold text-gray-800">Victoria Belmont</h4>
                    <p style="color:#1E3A5F" class="text-sm font-bold uppercase tracking-widest mt-1">Head of Sales</p>
                </div>
                <div class="text-center" data-aos="fade-up" data-aos-delay="300">
                    <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?auto=format&fit=crop&w=300&q=80" class="w-48 h-48 rounded-full object-cover mx-auto mb-6 border-4 border-[#1E3A5F]/20 grayscale hover:grayscale-0 transition-all">
                    <h4 class="text-xl font-bold text-gray-800">Julian Thorne</h4>
                    <p style="color:#1E3A5F" class="text-sm font-bold uppercase tracking-widest mt-1">Global Director</p>
                </div>
                <div class="text-center" data-aos="fade-up" data-aos-delay="400">
                    <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?auto=format&fit=crop&w=300&q=80" class="w-48 h-48 rounded-full object-cover mx-auto mb-6 border-4 border-[#1E3A5F]/20 grayscale hover:grayscale-0 transition-all">
                    <h4 class="text-xl font-bold text-gray-800">Elena Rostova</h4>
                    <p style="color:#1E3A5F" class="text-sm font-bold uppercase tracking-widest mt-1">Lead Architect</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
