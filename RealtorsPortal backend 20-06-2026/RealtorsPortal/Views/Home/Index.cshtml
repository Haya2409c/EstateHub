                <button id="scheduleVisitBtn" class="px-6 py-2.5 rounded-xl border border-[#1E3A5F] text-[#1E3A5F] font-bold text-sm hover:bg-[#1E3A5F] hover:text-white transition-colors ml-auto hidden sm:block">Schedule a Visit</button>
                <button id="detailActionBtn" class="px-6 py-2.5 rounded-xl bg-gold text-white font-bold text-sm hover:bg-yellow-600 transition-colors shadow-md">Inquire Now</button>
            </div>
        </div>
    </div>
}

<script>
(function () {
    var grid = document.getElementById('featured-grid');
    if (!grid) return;
    var cards = Array.from(grid.querySelectorAll('.property-card'));
    if (!cards.length) return;

    // Hide all cards initially
    cards.forEach(function (c) {
        c.style.opacity = '0';
        c.style.transform = 'translateY(40px)';
        c.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
    });

    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            // Animate all cards in the same row (same offsetTop)
            var rowTop = entry.target.offsetTop;
            cards.forEach(function (c) {
                if (c.offsetTop === rowTop) {
                    c.style.opacity = '1';
                    c.style.transform = 'translateY(0)';
                    observer.unobserve(c);
                }
            });
        });
    }, { threshold: 0.1 });

    cards.forEach(function (c) { observer.observe(c); });
})();
</script>
