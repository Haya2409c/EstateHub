@model RealtorsPortal.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="pt-32 pb-20 bg-deep min-h-screen flex items-center justify-center">
    <div class="text-center">
        <h1 class="text-4xl font-bold text-[#1E3A5F] mb-4">Error.</h1>
        <h2 class="text-gray-500">An error occurred while processing your request.</h2>
        @if (Model.ShowRequestId)
        {
            <p class="text-gray-400 text-sm mt-4">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }
    </div>
</section>
