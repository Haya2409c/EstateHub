@using RealtorsPortal.Models.Entities
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager
@{
    var currentUser = await UserManager.GetUserAsync(User);
    var userName = currentUser?.FullName ?? User.Identity?.Name ?? "Agent";
    var userEmail = currentUser?.Email ?? "";
    var nameParts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = nameParts.Length >= 2
        ? $"{nameParts[0][0]}{nameParts[1][0]}".ToUpper()
        : (userName.Length >= 2 ? userName.Substring(0, 2).ToUpper() : userName.ToUpper());
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string NavCls(string action) => currentAction == action
        ? "flex items-center gap-3 px-4 py-3 rounded-xl nav-active transition-theme"
        : "flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-theme";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] | Agent Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        navy: { 900: '#060B19', 800: '#0B132B', 700: '#1C2541', 600: '#3A506B' },
                        gold: { 400: '#F1C40F', 500: '#D4AF37', 600: '#AA8C2C' }
                    },
                    boxShadow: { 'gold-glow': '0 0 15px rgba(212,175,55,0.3)' }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/agent-dashboard.css">
</head>
<body class="font-sans antialiased h-screen flex overflow-hidden">

    <!-- SIDEBAR -->
    <aside id="sidebar" class="w-64 glass-panel flex-shrink-0 flex flex-col h-full transition-theme z-20 absolute lg:relative -translate-x-full lg:translate-x-0">

        <!-- Logo -->
        <div class="h-20 flex items-center px-6 border-b border-white/10">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-gold-500 flex items-center justify-center shadow-gold-glow">
                    <i class="fa-solid fa-gem text-navy-900 text-xl"></i>
                </div>
                <div>
                    <h1 class="font-bold text-xl tracking-wide text-white">Estate<span class="text-gold-500">Hub</span></h1>
                    <p class="text-xs text-gray-400">Agent Portal</p>
                </div>
            </div>
            <button id="closeSidebar" class="lg:hidden ml-auto text-gray-400 hover:text-white" title="Close sidebar" aria-label="Close sidebar">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <!-- Nav -->
        <nav class="flex-1 overflow-y-auto py-6 px-4 space-y-1">
            <a asp-controller="Agent" asp-action="Index" class="@NavCls("Index")">
                <i class="fa-solid fa-chart-pie w-5 text-center"></i>
                <span class="font-medium">Dashboard</span>
            </a>

            <div class="pt-4 pb-2">
                <p class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Properties</p>
            </div>
            <a asp-controller="Agent" asp-action="MyListings" class="@NavCls("MyListings")">
                <i class="fa-solid fa-building w-5 text-center"></i>
                <span class="font-medium">My Listings</span>
            </a>
            <a asp-controller="Agent" asp-action="CreateListing" class="@NavCls("CreateListing")">
                <i class="fa-solid fa-plus w-5 text-center"></i>
                <span class="font-medium">Add Property</span>
            </a>
            <a asp-controller="Agent" asp-action="UploadImages" class="@NavCls("UploadImages")">
                <i class="fa-regular fa-images w-5 text-center"></i>
                <span class="font-medium">Property Images</span>
            </a>

            <div class="pt-4 pb-2">
                <p class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Client Management</p>
            </div>
            <a asp-controller="Agent" asp-action="Leads" class="@NavCls("Leads")">
                <i class="fa-solid fa-users w-5 text-center"></i>
                <span class="font-medium">Leads Management</span>
            </a>

            <div class="pt-4 pb-2">
                <p class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Account</p>
            </div>
            <a asp-controller="Agent" asp-action="Packages" class="@NavCls("Packages")">
                <i class="fa-solid fa-cube w-5 text-center"></i>
                <span class="font-medium">Packages</span>
            </a>
            <a asp-controller="Agent" asp-action="Profile" class="@NavCls("Profile")">
                <i class="fa-solid fa-user-tie w-5 text-center"></i>
                <span class="font-medium">Profile Settings</span>
            </a>
            <a asp-controller="Agent" asp-action="Notifications" class="@NavCls("Notifications")">
                <i class="fa-regular fa-bell w-5 text-center"></i>
                <span class="font-medium">Notifications</span>
            </a>
        </nav>

        <!-- Sidebar Footer -->
        <div class="p-4 border-t border-white/10">
            <div class="flex items-center gap-3 px-4 py-3 mb-2">
                <div class="w-9 h-9 rounded-full bg-gold-500/20 border border-gold-500/30 flex items-center justify-center text-gold-500 font-bold text-sm flex-shrink-0">@initials</div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-white truncate">@userName</p>
                    <p class="text-xs text-gray-400 truncate">@userEmail</p>
                </div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" style="width:100%;">
                @Html.AntiForgeryToken()
                <button type="submit" class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-400 hover:bg-red-400/10 transition-theme w-full bg-transparent border-0 cursor-pointer">
                    <i class="fa-solid fa-arrow-right-from-bracket w-5 text-center"></i>
                    <span class="font-medium">Logout</span>
                </button>
            </form>
        </div>
    </aside>

    <!-- Mobile overlay -->
    <div id="sidebarOverlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-10 hidden lg:hidden"></div>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col h-full min-w-0 bg-[#060B19]">

        <!-- Top Navbar -->
        <header class="h-20 glass-panel flex items-center justify-between px-6 lg:px-8 z-10 sticky top-0 border-b border-white/10">
            <div class="flex items-center gap-4">
                <button id="openSidebar" class="lg:hidden text-gray-400 hover:text-white p-2 rounded-lg hover:bg-white/5">
                    <i class="fa-solid fa-bars text-xl"></i>
                </button>
                <div class="hidden sm:block text-white font-semibold text-lg">@(ViewData["PageHeading"] ?? ViewData["Title"])</div>
            </div>

            <div class="flex items-center gap-4 sm:gap-5">
                <a asp-controller="Agent" asp-action="CreateListing"
                   class="hidden sm:flex items-center gap-2 bg-gold-500 hover:bg-gold-600 text-navy-900 px-5 py-2 rounded-full font-semibold transition-theme shadow-gold-glow text-sm">
                    <i class="fa-solid fa-plus text-sm"></i> Add Listing
                </a>
                <a asp-controller="Agent" asp-action="Notifications" class="relative text-gray-400 hover:text-white p-2 rounded-full hover:bg-white/5">
                    <i class="fa-regular fa-bell text-xl"></i>
                </a>
                <div class="w-px h-8 bg-white/10 hidden sm:block"></div>
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-gold-500/20 border-2 border-gold-500 flex items-center justify-center text-gold-500 font-bold text-sm">@initials</div>
                    <div class="hidden md:block">
                        <p class="text-sm font-semibold text-white leading-tight">@userName</p>
                        <p class="text-xs text-gold-500">Agent</p>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="flex-1 overflow-y-auto">
            @if (TempData["Success"] != null)
            {
                <div class="mx-6 mt-4 p-3 bg-green-500/20 border border-green-500/30 text-green-400 rounded-xl text-sm flex items-center gap-2">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="mx-6 mt-4 p-3 bg-red-500/20 border border-red-500/30 text-red-400 rounded-xl text-sm flex items-center gap-2">
                    <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Sidebar toggle
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const openBtn = document.getElementById('openSidebar');
        const closeBtn = document.getElementById('closeSidebar');
        function toggleSidebar() {
            sidebar.classList.toggle('-translate-x-full');
            overlay.classList.toggle('hidden');
        }
        if (openBtn) openBtn.addEventListener('click', toggleSidebar);
        if (closeBtn) closeBtn.addEventListener('click', toggleSidebar);
        if (overlay) overlay.addEventListener('click', toggleSidebar);
        if (typeof AOS !== 'undefined') AOS.init({ duration: 700, once: true });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
