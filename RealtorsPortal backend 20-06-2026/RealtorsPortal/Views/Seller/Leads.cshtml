@using RealtorsPortal.Models.Entities
@{
    Layout = "_SellerLayout";
    ViewData["Title"] = "My Leads";
    ViewData["PageHeading"] = "My Leads";
    var leads          = ViewBag.Leads as List<PropertyEnquiry> ?? new();
    var totalLeads     = (int)(ViewBag.TotalLeads ?? 0);
    var unreadCount    = (int)(ViewBag.UnreadCount ?? 0);
    var totalPages     = (int)(ViewBag.TotalPages ?? 1);
    var currentPage    = (int)(ViewBag.CurrentPage ?? 1);
    var selectedStatus = ViewBag.SelectedStatus as string ?? "all";
}

<main class="flex-1 p-6 max-w-6xl mx-auto w-full pb-24 lg:pb-12">

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="glass-panel rounded-xl p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-purple-100 text-purple-600 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-users text-xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold text-[#1E3A5F]">@totalLeads</p>
                <p class="text-xs text-[#718096]">Total Leads</p>
            </div>
        </div>
        <div class="glass-panel rounded-xl p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-envelope text-xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold text-[#1E3A5F]">@unreadCount</p>
                <p class="text-xs text-[#718096]">Unread</p>
            </div>
        </div>
        <div class="glass-panel rounded-xl p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-green-100 text-green-600 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-envelope-open text-xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold text-[#1E3A5F]">@(totalLeads - unreadCount)</p>
                <p class="text-xs text-[#718096]">Read</p>
            </div>
        </div>
    </div>

    <!-- Filter -->
    <form method="get" asp-controller="Seller" asp-action="Leads" class="mb-6">
        <div class="glass-panel rounded-xl p-4 flex flex-wrap gap-3 items-center">
            <span class="text-sm text-[#718096] font-medium">Filter:</span>
            <select name="status" onchange="this.form.submit()"
                    class="border border-gray-200 rounded-lg px-3 py-2 text-sm text-[#1E3A5F] outline-none focus:border-[#1E3A5F]">
                <option value="all"    selected="@(selectedStatus == "all")">All</option>
                <option value="unread" selected="@(selectedStatus == "unread")">Unread</option>
                <option value="read"   selected="@(selectedStatus == "read")">Read</option>
            </select>
        </div>
    </form>

    <!-- Table -->
    <div class="glass-panel rounded-2xl overflow-hidden">
        @if (!leads.Any())
        {
            <div class="text-center py-16">
                <i class="fa-solid fa-inbox text-5xl text-gray-300 mb-4 block"></i>
                <h3 class="text-lg font-bold text-[#1E3A5F] mb-2">No Leads Yet</h3>
                <p class="text-[#718096] text-sm">Leads will appear here when visitors enquire about your listings.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm min-w-[700px]">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="p-4 pl-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Client</th>
                            <th class="p-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Contact</th>
                            <th class="p-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Property</th>
                            <th class="p-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
                            <th class="p-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="p-4 pr-6 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var lead in leads)
                        {
                            <tr class="hover:bg-gray-50 transition-colors @(!lead.IsRead ? "bg-blue-50/60" : "")">
                                <td class="p-4 pl-6">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-full bg-[#1E3A5F]/10 text-[#1E3A5F] flex items-center justify-center text-sm font-bold flex-shrink-0">
                                            @(lead.FullName.Length > 0 ? lead.FullName[0].ToString().ToUpper() : "?")
                                        </div>
                                        <div>
                                            <p class="font-semibold text-[#1E3A5F]">@lead.FullName</p>
                                            <p class="text-xs text-[#718096]">@lead.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-4 text-[#718096]">@(lead.Phone ?? "—")</td>
                                <td class="p-4">
                                    <p class="text-[#1E3A5F] line-clamp-1">@(lead.Property?.Title ?? "General Enquiry")</p>
                                </td>
                                <td class="p-4 text-[#718096]">@lead.SubmittedAt.ToString("MMM dd, yyyy")</td>
                                <td class="p-4">
                                    @if (lead.IsRead)
                                    {
                                        <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">Read</span>
                                    }
                                    else
                                    {
                                        <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700">New</span>
                                    }
                                </td>
                                <td class="p-4 pr-6 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        @if (!string.IsNullOrEmpty(lead.Message))
                                        {
                                            <button type="button" title="@lead.Message" onclick="showMsg(this)"
                                                    class="text-xs text-blue-600 hover:text-blue-800 px-2 py-1 rounded border border-blue-200 hover:bg-blue-50 transition-colors">
                                                <i class="fa-regular fa-envelope"></i> View
                                            </button>
                                        }
                                        @if (!lead.IsRead)
                                        {
                                            <form asp-controller="Seller" asp-action="MarkLeadRead" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@lead.Id" />
                                                <button type="submit" title="Mark as read"
                                                        class="text-xs text-green-600 hover:text-green-800 px-2 py-1 rounded border border-green-200 hover:bg-green-50 transition-colors">
                                                    <i class="fa-solid fa-check"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-controller="Seller" asp-action="DeleteLead" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@lead.Id" />
                                            <button type="submit" title="Delete"
                                                    class="text-xs text-red-500 hover:text-red-700 px-2 py-1 rounded border border-red-200 hover:bg-red-50 transition-colors">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="p-4 border-t border-gray-100 flex items-center justify-between text-sm text-[#718096]">
                    <span>Page @currentPage of @totalPages</span>
                    <div class="flex gap-1">
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <a asp-controller="Seller" asp-action="Leads" asp-route-page="@i" asp-route-status="@selectedStatus"
                               class="px-3 py-1 rounded text-sm transition-colors @(i == currentPage ? "bg-[#1E3A5F] text-white font-bold" : "bg-gray-100 hover:bg-gray-200 text-[#1E3A5F]")">@i</a>
                        }
                    </div>
                </div>
            }
        }
    </div>

</main>

<!-- Message Modal -->
<div id="msgModal" class="fixed inset-0 bg-black/60 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl p-6 max-w-md w-full shadow-2xl">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-[#1E3A5F]">Client Message</h3>
            <button onclick="document.getElementById('msgModal').classList.add('hidden')"
                    class="text-gray-400 hover:text-gray-700 transition-colors" title="Close" aria-label="Close">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
        <p id="msgContent" class="text-[#718096] text-sm leading-relaxed"></p>
    </div>
</div>

@section Scripts {
    <script>
        function showMsg(btn) {
            document.getElementById('msgContent').textContent = btn.title;
            document.getElementById('msgModal').classList.remove('hidden');
        }
    </script>
}
