@model List<RealtorsPortal.Models.Entities.Property>
@{
    Layout = "_SellerLayout";
    ViewData["Title"] = "My Properties";
    ViewData["PageHeading"] = "My Properties";
}

<main class="flex-1 p-6 max-w-7xl mx-auto w-full">

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 p-3 bg-green-100 text-green-700 rounded-lg font-poppins text-sm">@TempData["Success"]</div>
    }

    <!-- Top Bar (Filters & Actions) -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div class="w-full md:w-1/3 relative">
            <i class="fa-solid fa-search absolute left-4 top-1/2 -translate-y-1/2 text-[#718096]"></i>
            <input type="text" id="searchInput" placeholder="Search by name or location..." class="glass-panel w-full py-3 pl-10 pr-4 rounded-xl border-none outline-none focus:ring-2 focus:ring-[#1E3A5F] transition-all bg-white">
        </div>

        <div id="filter-container" class="flex gap-2 bg-white p-1 rounded-xl glass-panel border-none w-full md:w-auto overflow-x-auto">
            <button data-filter="all" class="filter-btn px-4 py-2 rounded-lg btn-gold text-sm whitespace-nowrap">All</button>
            <button data-filter="buy"  class="filter-btn px-4 py-2 rounded-lg text-[#718096] hover:bg-[#F4F6F9] hover:text-[#1E3A5F] font-medium text-sm transition-colors whitespace-nowrap">Buy</button>
            <button data-filter="rent" class="filter-btn px-4 py-2 rounded-lg text-[#718096] hover:bg-[#F4F6F9] hover:text-[#1E3A5F] font-medium text-sm transition-colors whitespace-nowrap">Rent</button>
            <button data-filter="sell" class="filter-btn px-4 py-2 rounded-lg text-[#718096] hover:bg-[#F4F6F9] hover:text-[#1E3A5F] font-medium text-sm transition-colors whitespace-nowrap">Sell</button>
        </div>

        <div class="w-full md:w-auto text-right">
            <a asp-controller="Seller" asp-action="CreateListing" class="btn-gold w-full md:w-auto justify-center">
                <i class="fa-solid fa-plus"></i> Add Property
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <!-- Empty State -->
        <div class="glass-panel p-12 flex flex-col items-center justify-center text-center">
            <i class="fa-solid fa-house-chimney text-6xl text-[#CBD5E0] mb-4"></i>
            <h3 class="font-outfit font-bold text-2xl text-[#1E3A5F] mb-2">No Properties Yet</h3>
            <p class="font-poppins text-[#718096] mb-6 max-w-md">List your first property now and reach thousands of buyers/renters.</p>
            <a asp-controller="Seller" asp-action="CreateListing" class="btn-gold px-8 py-3">
                <i class="fa-solid fa-plus"></i> Add Property
            </a>
        </div>
    }
    else
    {
        <!-- Property Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="propertyGrid">
            @foreach (var prop in Model)
            {
                var statusColor = prop.Status?.ToLower() switch {
                    "rent" => "bg-blue-100 text-blue-700",
                    "sell" => "bg-amber-100 text-amber-700",
                    _      => "bg-green-100 text-green-700"
                };
                var statusLabel = prop.Status?.ToLower() switch {
                    "rent" => "For Rent",
                    "sell" => "For Sale",
                    _      => "For Buy"
                };
                <div class="glass-panel overflow-hidden property-card" data-status="@prop.Status?.ToLower()" data-title="@prop.Title.ToLower()" data-address="@prop.Address?.ToLower()">
                    <!-- Property Image -->
                    @{
                        var primaryImage = prop.Images.FirstOrDefault(i => i.IsPrimary) ?? prop.Images.FirstOrDefault();
                    }
                    <div class="h-48 relative overflow-hidden">
                        @if (primaryImage != null)
                        {
                            <img src="@primaryImage.Url" alt="@prop.Title" class="w-full h-full object-cover">
                        }
                        else
                        {
                            <div class="w-full h-full bg-gradient-to-br from-[#1E3A5F] to-[#2D4A8A] flex items-center justify-center">
                                <i class="fa-solid fa-house text-white text-5xl opacity-30"></i>
                            </div>
                        }
                        <span class="absolute top-3 left-3 text-xs font-semibold px-2.5 py-1 rounded-full @statusColor">@statusLabel</span>
                        <span class="absolute top-3 right-3 text-xs font-semibold px-2.5 py-1 rounded-full bg-white/90 text-[#1E3A5F]">@(prop.PropertyType ?? "Property")</span>
                    </div>

                    <div class="p-5">
                        <h3 class="font-outfit font-bold text-lg text-[#1E3A5F] mb-1 truncate">@prop.Title</h3>
                        <p class="font-poppins text-sm text-[#718096] mb-3 flex items-center gap-1 truncate">
                            <i class="fa-solid fa-location-dot text-[#2563EB] flex-shrink-0"></i>
                            @(prop.Address ?? "—")
                        </p>

                        <!-- Specs -->
                        <div class="flex items-center gap-4 text-sm text-[#718096] font-poppins mb-4">
                            @if (prop.Bedrooms.HasValue)
                            {
                                <span><i class="fa-solid fa-bed mr-1 text-[#2563EB]"></i>@prop.Bedrooms</span>
                            }
                            @if (prop.Bathrooms.HasValue)
                            {
                                <span><i class="fa-solid fa-shower mr-1 text-[#2563EB]"></i>@prop.Bathrooms</span>
                            }
                            @if (prop.AreaSqft.HasValue)
                            {
                                <span><i class="fa-solid fa-ruler-combined mr-1 text-[#2563EB]"></i>@prop.AreaSqft sqft</span>
                            }
                        </div>

                        <!-- Price + Actions -->
                        <div class="flex items-center justify-between border-t border-[#1E3A5F]/10 pt-4">
                            <div class="font-outfit font-bold text-xl text-[#1E3A5F]">
                                PKR @prop.Price.ToString("N0")
                            </div>
                            <div class="flex gap-2">
                                <a asp-controller="Seller" asp-action="EditListing" asp-route-id="@prop.Id"
                                   class="w-9 h-9 rounded-lg bg-[#F4F6F9] hover:bg-[#1E3A5F] text-[#1E3A5F] hover:text-white flex items-center justify-center transition-colors" title="Edit">
                                    <i class="fa-solid fa-pen-to-square text-sm"></i>
                                </a>
                                <button type="button"
                                        class="w-9 h-9 rounded-lg bg-red-50 hover:bg-red-500 text-red-500 hover:text-white flex items-center justify-center transition-colors"
                                        title="Delete" onclick="openDeleteModal(@prop.Id)">
                                    <i class="fa-solid fa-trash text-sm"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</main>

<!-- Delete Modal -->
<div class="detailOverlay" id="deleteModal">
    <div class="modal-content text-center">
        <button class="modal-close-btn" data-modal-close title="Close" aria-label="Close"><i class="fa-solid fa-times"></i></button>
        <div class="w-16 h-16 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4 text-red-500 text-2xl">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h2 class="font-outfit font-bold text-xl text-[#1E3A5F] mb-2">Delete Property?</h2>
        <p class="font-poppins text-[#718096] mb-6 text-sm">Are you sure you want to delete this property? This action cannot be undone.</p>
        <div class="flex gap-4 justify-center">
            <button class="btn-outline-navy w-32" data-modal-close>Cancel</button>
            <form id="deleteForm" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-gold w-32" style="background-color:#ef4444;border-color:#ef4444;">Delete</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openDeleteModal(id) {
        document.getElementById('deleteForm').action = '/Seller/DeleteListing/' + id;
        document.getElementById('deleteModal').classList.add('active');
    }

    // Search filter
    document.getElementById('searchInput').addEventListener('input', function() {
        filterCards();
    });

    let activeFilter = 'all';
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            activeFilter = this.dataset.filter;
            document.querySelectorAll('.filter-btn').forEach(b => {
                b.className = 'filter-btn px-4 py-2 rounded-lg text-[#718096] hover:bg-[#F4F6F9] hover:text-[#1E3A5F] font-medium text-sm transition-colors whitespace-nowrap';
            });
            this.className = 'filter-btn px-4 py-2 rounded-lg btn-gold text-sm whitespace-nowrap';
            filterCards();
        });
    });

    function filterCards() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('.property-card').forEach(card => {
            const matchesFilter = activeFilter === 'all' || card.dataset.status === activeFilter;
            const matchesSearch = !search || card.dataset.title.includes(search) || (card.dataset.address && card.dataset.address.includes(search));
            card.style.display = matchesFilter && matchesSearch ? '' : 'none';
        });
    }
</script>
}
