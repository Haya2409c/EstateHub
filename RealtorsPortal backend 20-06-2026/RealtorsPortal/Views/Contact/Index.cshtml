@model RealtorsPortal.Models.ViewModels.Contact.ContactPageViewModel
@{
    ViewData["Title"] = "Contact Us";
}
<!-- Header -->
    <section class="pt-32 pb-20 bg-deep border-b border-gray-200 relative overflow-hidden">
        <div class="absolute inset-0 bg-[#1E3A5F]/40"></div>
        <div class="container mx-auto px-6 text-center relative z-10">
            <span class="text-gold uppercase tracking-[0.3em] text-sm font-semibold mb-4 block" data-aos="fade-up">Elite Support</span>
            <h1 class="text-5xl md:text-7xl font-bold text-white" data-aos="fade-up" data-aos-delay="100">
                Get In <span class="italic font-normal" style="color: #93C5FD;">Touch</span>
            </h1>
            <p class="max-w-2xl mx-auto" style="color: rgba(255,255,255,0.85);" data-aos="fade-up" data-aos-delay="200">Our concierge team is available 24/7 to assist you with your luxury real estate needs.</p>
        </div>
    </section>

    <!-- Contact Form & Info -->
    <section class="py-20 container mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
            <div data-aos="fade-right">
                <h2 class="text-4xl font-bold mb-8">Visit Our <span class="text-gold">Global Offices</span></h2>
                <div class="space-y-12">
                    <div class="flex gap-6">
                        <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center shrink-0"><i class="fas fa-map-marker-alt text-gold"></i></div>
                        <div>
                            <h4 class="font-bold text-xl mb-2">Dubai (HQ)</h4>
                            <p class="text-gray-500">The Opus by Omniyat, Business Bay<br>Dubai, United Arab Emirates</p>
                        </div>
                    </div>
                    <div class="flex gap-6">
                        <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center shrink-0"><i class="fas fa-phone text-gold"></i></div>
                        <div>
                            <h4 class="font-bold text-xl mb-2">Direct Contact</h4>
                            <p class="text-gray-500">Phone: +971 4 555 1234<br>Email: elite@luxeestate.com</p>
                        </div>
                    </div>
                </div>

                <div class="mt-16 h-80 rounded-3xl overflow-hidden border border-gray-200 grayscale">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3610.178653903123!2d55.2721!3d25.1872!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjXCsDExJzEzLjkiTiA1NcKwMTYnMTkuNiJF!5e0!3m2!1sen!2sae!4v1653150000000" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                </div>
            </div>

            <div class="glass-panel p-10 rounded-3xl" data-aos="fade-left">
                <h3 class="text-2xl font-bold mb-8">Send a Message</h3>

                @if (TempData["Success"] != null)
                {
                    <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-xl text-sm font-medium">
                        @TempData["Success"]
                    </div>
                }

                <form asp-action="Index" asp-controller="Contact" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <style>.validation-summary-valid { display: none; }</style>
                    <div asp-validation-summary="All" class="p-4 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm"></div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label asp-for="Form.FullName" class="text-xs uppercase tracking-widest font-bold text-gray-500">Full Name</label>
                            <input asp-for="Form.FullName" type="text" placeholder="Your full name"
                                   class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 outline-none focus:border-navy transition-all text-gray-800">
                            <span asp-validation-for="Form.FullName" class="text-red-500 text-xs"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="Form.Email" class="text-xs uppercase tracking-widest font-bold text-gray-500">Email Address</label>
                            <input asp-for="Form.Email" type="email" placeholder="your@email.com"
                                   class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 outline-none focus:border-navy transition-all text-gray-800">
                            <span asp-validation-for="Form.Email" class="text-red-500 text-xs"></span>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="Form.Phone" class="text-xs uppercase tracking-widest font-bold text-gray-500">Phone (Optional)</label>
                        <input asp-for="Form.Phone" type="tel" placeholder="+92 300 0000000"
                               class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 outline-none focus:border-navy transition-all text-gray-800">
                    </div>

                    <div class="space-y-2">
                        <label asp-for="Form.Subject" class="text-xs uppercase tracking-widest font-bold text-gray-500">Subject</label>
                        <select asp-for="Form.Subject" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 outline-none focus:border-navy transition-all text-gray-800">
                            <option value="">-- Select a subject --</option>
                            <option value="Property Inquiry">Property Inquiry</option>
                            <option value="Sell My Property">Sell My Property</option>
                            <option value="Investment Advice">Investment Advice</option>
                            <option value="Agent Support">Agent Support</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Form.Subject" class="text-red-500 text-xs"></span>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="Form.Message" class="text-xs uppercase tracking-widest font-bold text-gray-500">Message</label>
                        <textarea asp-for="Form.Message" rows="6" placeholder="Tell us how we can help..."
                                  class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 outline-none focus:border-navy transition-all text-gray-800"></textarea>
                        <span asp-validation-for="Form.Message" class="text-red-500 text-xs"></span>
                    </div>

                    <button type="submit" class="w-full btn-gold !py-5">Submit Inquiry</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->

@section Scripts {
    <script>

        AOS.init({
            duration: 800,
            once: true,
            offset: 0,
            startEvent: 'DOMContentLoaded',
            initClassName: 'aos-init',
            animatedClassName: 'aos-animate',
            mirror: false,
            anchorPlacement: 'top-bottom'
        });

        // Force AOS to re-check all elements after page fully loads
        window.addEventListener('load', function() {
            AOS.refresh();
        });

    </script>
}
