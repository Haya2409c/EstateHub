@using RealtorsPortal.Models.Entities
@{
    Layout = "_AgentLayout";
    ViewData["Title"] = "Notifications";
    ViewData["PageHeading"] = "Notifications";
    var notifications = ViewBag.Notifications as List<PropertyEnquiry> ?? new();
    var unreadCount   = (int)(ViewBag.UnreadCount ?? 0);
}

<main class="p-6 lg:p-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6" data-aos="fade-down">
        <div>
            <h2 class="text-2xl font-bold text-white">Notifications</h2>
            <p class="text-gray-400 text-sm mt-1">@unreadCount unread notification(s)</p>
        </div>
        @if (unreadCount > 0)
        {
            <a asp-controller="Agent" asp-action="Leads" class="btn-gold-agent text-sm">
                <i class="fa-solid fa-check-double"></i> View All Leads
            </a>
        }
    </div>

    @if (!notifications.Any())
    {
        <div class="glass-card rounded-2xl p-16 text-center">
            <i class="fa-regular fa-bell text-6xl text-gray-600 mb-4 block"></i>
            <h3 class="text-xl font-bold text-white mb-2">No Notifications</h3>
            <p class="text-gray-400 text-sm">When visitors enquire about your listings, you'll see notifications here.</p>
        </div>
    }
    else
    {
        <div class="space-y-3 max-w-3xl" data-aos="fade-up">
            @{
                var today = DateTime.Today;
                var yesterday = today.AddDays(-1);
                string? lastGroup = null;
            }
            @foreach (var n in notifications)
            {
                var nDate = n.SubmittedAt.Date;
                var group = nDate == today ? "Today" : (nDate == yesterday ? "Yesterday" : n.SubmittedAt.ToString("MMMM dd, yyyy"));
                if (group != lastGroup)
                {
                    lastGroup = group;
                    <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mt-6 mb-3 border-b border-white/10 pb-2">@group</div>
                }
                <div class="glass-card rounded-xl p-5 flex gap-4 items-start @(n.IsRead ? "" : "border border-blue-500/20 bg-blue-500/5") hover:bg-white/5 transition-theme">
                    <div class="w-10 h-10 rounded-full @(n.IsRead ? "bg-gray-700 text-gray-400" : "bg-blue-500/20 text-blue-400") flex items-center justify-center text-lg flex-shrink-0">
                        <i class="fa-solid fa-envelope@(n.IsRead ? "-open" : "")"></i>
                    </div>
                    <div class="flex-1">
                        <div class="flex justify-between items-start mb-1">
                            <h4 class="font-semibold @(n.IsRead ? "text-gray-300" : "text-white")">
                                New Lead: @n.FullName
                                @if (!n.IsRead) { <span class="ml-2 w-2 h-2 inline-block rounded-full bg-blue-400"></span> }
                            </h4>
                            <span class="text-xs text-gray-500 flex-shrink-0 ml-4">@n.SubmittedAt.ToString("hh:mm tt")</span>
                        </div>
                        <p class="text-gray-400 text-sm">
                            <span class="text-gray-300">@n.Email</span> enquired about
                            <span class="text-gold-500 font-medium">@(n.Property?.Title ?? "your property")</span>
                        </p>
                        @if (!string.IsNullOrEmpty(n.Message))
                        {
                            <p class="text-gray-500 text-xs mt-1 line-clamp-2">"@n.Message"</p>
                        }
                        <div class="mt-3 flex gap-3">
                            @if (!n.IsRead)
                            {
                                <form asp-controller="Agent" asp-action="MarkLeadRead" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@n.Id">
                                    <button type="submit" class="text-xs text-green-400 hover:text-green-300 transition-theme font-medium">
                                        <i class="fa-solid fa-check mr-1"></i> Mark Read
                                    </button>
                                </form>
                            }
                            <a asp-controller="Agent" asp-action="Leads" class="text-xs text-gold-500 hover:text-gold-400 transition-theme font-medium">View in Leads →</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</main>
