@model List<RealtorsPortal.Models.Entities.Property>
@{
    Layout = "_AgentLayout";
    ViewData["Title"] = "My Listings";
    ViewData["PageHeading"] = "My Listings";
}

<main class="p-6 lg:p-8">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6" data-aos="fade-down">
        <div>
            <h2 class="text-2xl font-bold text-white">My Properties</h2>
            <p class="text-gray-400 text-sm mt-1">@Model.Count total listing(s)</p>
        </div>
        <a asp-controller="Agent" asp-action="CreateListing" class="btn-gold-agent">
            <i class="fa-solid fa-plus"></i> Add New Listing
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-card rounded-2xl p-16 flex flex-col items-center text-center">
            <i class="fa-solid fa-house-chimney text-6xl text-gray-600 mb-4"></i>
            <h3 class="text-xl font-bold text-white mb-2">No Listings Yet</h3>
            <p class="text-gray-400 mb-6">Start adding properties to build your portfolio.</p>
            <a asp-controller="Agent" asp-action="CreateListing" class="btn-gold-agent">
                <i class="fa-solid fa-plus"></i> Add Your First Property
            </a>
        </div>
    }
    else
    {
        <!-- Search bar -->
        <div class="glass-card rounded-xl p-4 mb-6 flex gap-3">
            <div class="flex-1 flex items-center gap-3 bg-navy-800/50 border border-white/10 rounded-lg px-4 py-2">
                <i class="fa-solid fa-search text-gray-400"></i>
                <input type="text" id="searchInput" placeholder="Search properties..." class="bg-transparent text-sm text-white placeholder-gray-500 outline-none w-full">
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5" id="listingsGrid">
            @foreach (var p in Model)
            {
                var thumb = p.Images.FirstOrDefault(i => i.IsPrimary)?.Url
                    ?? p.Images.OrderBy(i => i.SortOrder).FirstOrDefault()?.Url;
                var statusLabel = p.Status switch { "buy" => "For Buy", "rent" => "For Rent", "sell" => "For Sale", _ => "Listed" };
                var statusColor = p.Status switch { "buy" => "bg-blue-500/20 text-blue-400 border-blue-500/20", "rent" => "bg-green-500/20 text-green-400 border-green-500/20", _ => "bg-gold-500/20 text-gold-500 border-gold-500/20" };
                var approvalLabel = p.ApprovalStatus switch { "Active" => "Active", "Rejected" => "Rejected", _ => "Pending" };
                var approvalColor = p.ApprovalStatus switch { "Active" => "bg-green-500/20 text-green-400 border-green-500/30", "Rejected" => "bg-red-500/20 text-red-400 border-red-500/30", _ => "bg-yellow-500/20 text-yellow-400 border-yellow-500/30" };

                <div class="glass-card rounded-2xl overflow-hidden flex flex-col property-card" data-title="@p.Title.ToLower()" data-aos="fade-up">
                    <div class="relative h-48 flex-shrink-0">
                        @if (!string.IsNullOrEmpty(thumb))
                        {
                            <img src="@thumb" class="w-full h-full object-cover"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                            <div class="w-full h-full bg-gray-800 items-center justify-center" style="display:none">
                                <i class="fas fa-home text-gray-600 text-4xl"></i>
                            </div>
                        }
                        else
                        {
                            <div class="w-full h-full bg-gray-800 flex items-center justify-center">
                                <i class="fas fa-home text-gray-600 text-4xl"></i>
                            </div>
                        }
                        <span class="absolute top-3 left-3 px-2 py-1 text-xs font-bold rounded-full border @statusColor">@statusLabel</span>
                        <span class="absolute top-3 right-3 px-2 py-1 text-xs font-bold rounded-full border @approvalColor">@approvalLabel</span>
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <p class="text-gold-500 font-bold text-lg mb-1">PKR @p.Price.ToString("N0")</p>
                        <h3 class="text-white font-semibold mb-1 line-clamp-2">@p.Title</h3>
                        <p class="text-gray-400 text-xs mb-4 flex items-center gap-1">
                            <i class="fa-solid fa-location-dot text-gold-500"></i> @p.Address
                        </p>
                        <div class="flex items-center gap-4 text-xs text-gray-400 border-t border-white/10 pt-3 mt-auto mb-4">
                            @if (p.Bedrooms.HasValue) { <span><i class="fa-solid fa-bed mr-1 text-blue-400"></i>@p.Bedrooms</span> }
                            @if (p.Bathrooms.HasValue) { <span><i class="fa-solid fa-bath mr-1 text-blue-400"></i>@p.Bathrooms</span> }
                            @if (p.AreaSqft.HasValue) { <span><i class="fa-solid fa-ruler-combined mr-1 text-blue-400"></i>@p.AreaSqft sqft</span> }
                            <span class="ml-auto text-gray-500">@p.Images.Count img(s)</span>
                        </div>
                        <div class="flex gap-2">
                            <a asp-controller="Agent" asp-action="EditListing" asp-route-id="@p.Id"
                               class="flex-1 btn-gold-agent justify-center text-sm py-2">
                                <i class="fa-solid fa-pen-to-square"></i> Edit
                            </a>
                            <a asp-controller="Agent" asp-action="UploadImages" asp-route-listingId="@p.Id"
                               class="px-3 py-2 rounded-lg glass-card border border-white/10 text-blue-400 hover:text-blue-300 text-sm transition-theme" title="Manage Images">
                                <i class="fa-regular fa-images"></i>
                            </a>
                            <button type="button" onclick="confirmDelete(@p.Id, '@p.Title.Replace("'","\\'")')"
                                    class="px-3 py-2 rounded-lg glass-card border border-red-500/20 text-red-400 hover:bg-red-500/10 text-sm transition-theme" title="Delete">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Delete modal (hidden) -->
    <div id="deleteModal" class="fixed inset-0 bg-black/70 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="glass-card rounded-2xl p-8 max-w-sm w-full text-center border border-red-500/20">
            <div class="w-16 h-16 rounded-full bg-red-500/20 flex items-center justify-center mx-auto mb-4">
                <i class="fa-solid fa-triangle-exclamation text-red-400 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Delete Listing?</h3>
            <p class="text-gray-400 text-sm mb-6" id="deleteModalMsg"></p>
            <div class="flex gap-3">
                <button onclick="document.getElementById('deleteModal').classList.add('hidden')"
                        class="flex-1 btn-outline-agent py-3">Cancel</button>
                <form id="deleteForm" method="post" class="flex-1">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full py-3 rounded-xl bg-red-500 hover:bg-red-600 text-white font-semibold text-sm transition-theme">Delete</button>
                </form>
            </div>
        </div>
    </div>

</main>

@section Scripts {
<script>
    function confirmDelete(id, title) {
        document.getElementById('deleteModalMsg').textContent = 'Are you sure you want to delete "' + title + '"? This cannot be undone.';
        document.getElementById('deleteForm').action = '/Agent/DeleteListing/' + id;
        document.getElementById('deleteModal').classList.remove('hidden');
    }
    document.getElementById('searchInput')?.addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.property-card').forEach(card => {
            card.style.display = card.dataset.title.includes(q) ? '' : 'none';
        });
    });
</script>
}
