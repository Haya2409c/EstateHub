@using RealtorsPortal.Models.Entities
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager
@model RealtorsPortal.Models.ViewModels.ProfileUpdateViewModel
@{
    Layout = "_AgentLayout";
    ViewData["Title"] = "Profile Settings";
    ViewData["PageHeading"] = "Profile Settings";
    var currentUser  = await UserManager.GetUserAsync(User);
    var fullName     = currentUser?.FullName ?? User.Identity?.Name ?? "Agent";
    var email        = currentUser?.Email ?? "";
    var phone        = currentUser?.PhoneNumber ?? "";
    var memberSince  = currentUser?.CreatedAt.ToString("MMMM yyyy") ?? "—";
    var initials     = fullName.Length >= 2 ? fullName.Substring(0, 2).ToUpper() : fullName.ToUpper();
    var photoUrl     = currentUser?.PhotoUrl;
}

<main class="p-6 lg:p-8">
    <form asp-controller="Agent" asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- Left: Avatar card -->
            <div class="w-full lg:w-72 flex-shrink-0">
                <div class="glass-card rounded-2xl p-8 text-center sticky top-24">
                    <!-- Photo preview -->
                    <div class="w-32 h-32 rounded-full border-4 border-gold-500/50 mx-auto mb-5 shadow-gold-glow overflow-hidden relative group cursor-pointer"
                         onclick="document.getElementById('photoInput').click()">
                        @if (!string.IsNullOrEmpty(photoUrl))
                        {
                            <img id="photoPreview" src="@photoUrl" alt="@fullName"
                                 class="w-full h-full object-cover"
                                 onerror="this.style.display='none';document.getElementById('photoInitials').style.display='flex'">
                            <div id="photoInitials" class="w-full h-full bg-gold-500/20 flex items-center justify-center absolute inset-0" style="display:none">
                                <span class="text-4xl font-bold text-gold-500">@initials</span>
                            </div>
                        }
                        else
                        {
                            <img id="photoPreview" src="" alt="" class="w-full h-full object-cover hidden">
                            <div id="photoInitials" class="w-full h-full bg-gold-500/20 flex items-center justify-center">
                                <span class="text-4xl font-bold text-gold-500">@initials</span>
                            </div>
                        }
                        <div class="absolute inset-0 bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity rounded-full">
                            <i class="fa-solid fa-camera text-white text-xl"></i>
                        </div>
                    </div>
                    <input type="file" id="photoInput" name="Photo" accept=".jpg,.jpeg,.png,.webp" class="hidden"
                           onchange="previewPhoto(this)">
                    <p class="text-xs text-gray-500 mb-4">Click photo to change · JPG, PNG, WebP</p>

                    <h2 class="text-xl font-bold text-white mb-1">@fullName</h2>
                    <p class="text-sm text-gray-400 mb-4">@email</p>
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-green-500/20 text-green-400 rounded-lg text-xs font-medium border border-green-500/30 mb-5">
                        <i class="fa-solid fa-shield-check"></i> Verified Agent
                    </div>
                    <div class="border-t border-white/10 pt-5 space-y-3 text-left">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Member Since</span>
                            <span class="text-white font-medium">@memberSince</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Account Type</span>
                            <span class="text-white font-medium">Agent</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Form -->
            <div class="flex-1 space-y-6">

                <!-- Personal Info -->
                <div class="glass-card rounded-2xl p-6">
                    <h2 class="text-lg font-bold text-white mb-5 border-b border-white/10 pb-3">
                        <i class="fa-solid fa-user text-gold-500 mr-2"></i> Personal Information
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-gray-400 mb-2">Full Name <span class="text-red-400">*</span></label>
                            <input type="text" name="FullName" value="@fullName" required class="agent-input">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-400 mb-2">Email</label>
                            <input type="email" value="@email" class="agent-input opacity-60 cursor-not-allowed" readonly>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-400 mb-2">Phone Number</label>
                            <input type="tel" name="Phone" value="@phone" placeholder="+92 300 0000000" class="agent-input">
                        </div>
                    </div>
                </div>

                <!-- Change Password -->
                <div class="glass-card rounded-2xl p-6">
                    <h2 class="text-lg font-bold text-white mb-5 border-b border-white/10 pb-3">
                        <i class="fa-solid fa-lock text-gold-500 mr-2"></i> Change Password
                    </h2>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm text-gray-400 mb-2">Current Password</label>
                            <input type="password" name="CurrentPassword" placeholder="Enter current password" class="agent-input">
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm text-gray-400 mb-2">New Password</label>
                                <input type="password" name="NewPassword" placeholder="Min 8 characters" class="agent-input">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-400 mb-2">Confirm Password</label>
                                <input type="password" name="ConfirmPassword" placeholder="Repeat new password" class="agent-input">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex justify-end gap-3 pb-8">
                    <button type="reset" class="btn-outline-agent px-8 py-3">Reset</button>
                    <button type="submit" class="btn-gold-agent px-8 py-3">
                        <i class="fa-solid fa-check"></i> Save Profile
                    </button>
                </div>

            </div>
        </div>
    </form>
</main>

<script>
function previewPhoto(input) {
    if (!input.files || !input.files[0]) return;
    var reader = new FileReader();
    reader.onload = function (e) {
        var preview = document.getElementById('photoPreview');
        var initials = document.getElementById('photoInitials');
        preview.src = e.target.result;
        preview.classList.remove('hidden');
        if (initials) initials.style.display = 'none';
    };
    reader.readAsDataURL(input.files[0]);
}
</script>
