@model RealtorsPortal.Models.ViewModels.CreateListingViewModel
@{
    Layout = "_AgentLayout";
    ViewData["Title"] = "Edit Property";
    ViewData["PageHeading"] = "Edit Property";
    var propertyId = (int)ViewBag.PropertyId;
    var existingImages = ViewBag.ExistingImages as List<RealtorsPortal.Models.Entities.PropertyImage> ?? new();
    var amenities = Model.Amenities ?? new List<string>();
}

<main class="p-6 lg:p-8 max-w-4xl">

    <form asp-controller="Agent" asp-action="EditListing" asp-route-id="@propertyId"
          method="post" enctype="multipart/form-data" class="space-y-6">
        @Html.AntiForgeryToken()

        <!-- Basic Info -->
        <div class="glass-card rounded-2xl p-6">
            <h2 class="text-lg font-bold text-white mb-5 border-b border-white/10 pb-3">
                <i class="fa-solid fa-info-circle text-gold-500 mr-2"></i> Basic Information
            </h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm text-gray-400 mb-2">Title <span class="text-red-400">*</span></label>
                    <input type="text" name="Title" value="@Model.Title" required class="agent-input">
                </div>
                <div>
                    <label class="block text-sm text-gray-400 mb-2">Description <span class="text-red-400">*</span></label>
                    <textarea name="Description" rows="5" required class="agent-input resize-none">@Model.Description</textarea>
                </div>
                <div>
                    <label class="block text-sm text-gray-400 mb-2">Property Type <span class="text-red-400">*</span></label>
                    <select name="PropertyType" required class="agent-input agent-select">
                        <option value="house"      selected="@(Model.PropertyType == "house")">House</option>
                        <option value="apartment"  selected="@(Model.PropertyType == "apartment")">Apartment</option>
                        <option value="plot"       selected="@(Model.PropertyType == "plot")">Plot</option>
                        <option value="commercial" selected="@(Model.PropertyType == "commercial")">Commercial Space</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Status -->
        <div class="glass-card rounded-2xl p-6">
            <h2 class="text-lg font-bold text-white mb-5 border-b border-white/10 pb-3">
                <i class="fa-solid fa-tag text-gold-500 mr-2"></i> Property Status
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                @foreach (var (val, label, icon) in new[]{("buy","For Buy","fa-tag"),("rent","For Rent","fa-key"),("sell","For Sale","fa-briefcase")})
                {
                    <label class="cursor-pointer">
                        <input type="radio" name="Status" value="@val" class="peer hidden" @(Model.Status == val ? "checked" : "")>
                        <div class="border-2 border-white/10 peer-checked:border-gold-500 peer-checked:bg-gold-500/5 rounded-xl p-4 text-center transition-theme hover:border-gold-500/50">
                            <i class="fa-solid @icon text-2xl text-gold-500 mb-2"></i>
                            <div class="font-semibold text-white text-sm">@label</div>
                        </div>
                    </label>
                }
            </div>
        </div>

        <!-- Location -->
        <div class="glass-card rounded-2xl p-6">
            <h2 class="text-lg font-bold text-white mb-5 border-b border-white/10 pb-3">
                <i class="fa-solid fa-location-dot text-gold-500 mr-2"></i> Location
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-sm text-gray-400 mb-2">Region</label>
                    <select name="Region" class="agent-input agent-select">
                        <option value="sindh">Sindh</option><option value="punjab">Punjab</option>
                        <option value="kpk">KPK</option><option value="balochistan">Balochistan</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm text-gray-400 mb-2">City</label>
                    <select name="City" class="agent-input agent-select">
                        <option value="karachi">Karachi</option><option value="lahore">Lahore</option>
                        <option value="islamabad">Islamabad</option><option value="peshawar">Peshawar</option>
                        <option value="quetta">Quetta</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm text-gray-400 mb-2">Full Address <span class="text-red-400">*</span></label>
                <input type="text" name="Address" value="@Model.Address" required class="agent-input">
            </div>
        </div>

        <!-- Details -->
        <div class="glass-card rounded-2xl p-6">
            <h2 class="text-lg font-bold text-white mb-5 border-b border-white/10 pb-3">
                <i class="fa-solid fa-list text-gold-500 mr-2"></i> Property Details
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                <div><label class="block text-sm text-gray-400 mb-2">Price (PKR) *</label><input type="number" name="Price" value="@Model.Price" required class="agent-input"></div>
                <div><label class="block text-sm text-gray-400 mb-2">Bedrooms</label><input type="number" name="Bedrooms" value="@Model.Bedrooms" class="agent-input" min="0"></div>
                <div><label class="block text-sm text-gray-400 mb-2">Bathrooms</label><input type="number" name="Bathrooms" value="@Model.Bathrooms" class="agent-input" min="0"></div>
                <div><label class="block text-sm text-gray-400 mb-2">Area (sqft)</label><input type="number" name="AreaSqft" value="@Model.AreaSqft" class="agent-input" min="0"></div>
            </div>
        </div>

        <!-- Amenities -->
        <div class="glass-card rounded-2xl p-6">
            <h2 class="text-lg font-bold text-white mb-5 border-b border-white/10 pb-3">
                <i class="fa-solid fa-star text-gold-500 mr-2"></i> Amenities
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                @foreach (var (val, label, icon) in new[]{("wifi","WiFi","fa-wifi"),("gym","Gym","fa-dumbbell"),("pool","Swimming Pool","fa-swimmer"),("security","Security","fa-shield-alt"),("elevator","Elevator","fa-sort"),("garden","Garden","fa-leaf")})
                {
                    <label class="flex items-center gap-3 cursor-pointer glass-card rounded-xl px-4 py-3 border border-white/5 hover:border-gold-500/30 transition-theme">
                        <input type="checkbox" name="Amenities" value="@val" class="accent-yellow-400" @(amenities.Contains(val) ? "checked" : "")>
                        <i class="fas @icon text-gold-500"></i>
                        <span class="text-sm text-gray-300">@label</span>
                    </label>
                }
            </div>
        </div>

        <!-- Add New Images -->
        <div class="glass-card rounded-2xl p-6">
            <h2 class="text-lg font-bold text-white mb-5 border-b border-white/10 pb-3">
                <i class="fa-regular fa-images text-gold-500 mr-2"></i> Add New Images
            </h2>
            <div class="border-2 border-dashed border-white/10 hover:border-gold-500/50 rounded-xl p-8 text-center transition-theme cursor-pointer"
                 onclick="document.getElementById('imgInputEdit').click()">
                <i class="fa-solid fa-cloud-arrow-up text-3xl text-gold-500 mb-2"></i>
                <p class="text-white font-medium text-sm">Click to browse or drag & drop</p>
                <input type="file" id="imgInputEdit" name="Images" class="hidden" multiple accept="image/*">
            </div>
            <div id="editPreview" class="flex flex-wrap gap-3 mt-4"></div>
        </div>

        <!-- Submit -->
        <div class="flex justify-end gap-3 pb-8">
            <a asp-controller="Agent" asp-action="MyListings" class="btn-outline-agent px-8 py-3">Cancel</a>
            <button type="submit" class="btn-gold-agent px-8 py-3">
                <i class="fa-solid fa-check"></i> Save Changes
            </button>
        </div>
    </form>

    @* Existing images OUTSIDE form *@
    @if (existingImages.Any())
    {
        <div class="glass-card rounded-2xl p-6 mt-6">
            <h2 class="text-lg font-bold text-white mb-4 border-b border-white/10 pb-3">
                Current Images <span class="text-xs font-normal text-gray-400 ml-2">hover to delete</span>
            </h2>
            <div class="flex flex-wrap gap-4">
                @foreach (var img in existingImages)
                {
                    <div class="w-28 h-28 flex-shrink-0 rounded-xl overflow-hidden relative group">
                        <img src="@img.Url" class="w-full h-full object-cover" onerror="this.src='/assets/images/new-property-1.jpg'">
                        @if (img.IsPrimary) { <span class="absolute top-1 left-1 bg-gold-500 text-navy-900 text-[9px] font-bold px-1.5 py-0.5 rounded-full">Primary</span> }
                        <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity">
                            <form asp-controller="Agent" asp-action="DeleteImage" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="imageId" value="@img.Id">
                                <input type="hidden" name="listingId" value="@propertyId">
                                <button type="submit" class="w-10 h-10 rounded-full bg-red-500 hover:bg-red-600 text-white flex items-center justify-center transition-colors" title="Delete">
                                    <i class="fa-solid fa-trash text-sm"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</main>

@section Scripts {
<script>
    document.getElementById('imgInputEdit').addEventListener('change', function() {
        const c = document.getElementById('editPreview');
        c.innerHTML = '';
        Array.from(this.files).forEach(file => {
            const reader = new FileReader();
            reader.onload = e => {
                const d = document.createElement('div');
                d.className = 'w-20 h-20 rounded-lg overflow-hidden flex-shrink-0';
                d.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover">`;
                c.appendChild(d);
            };
            reader.readAsDataURL(file);
        });
    });
</script>
}
