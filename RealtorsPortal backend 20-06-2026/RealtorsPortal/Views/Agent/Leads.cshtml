@using RealtorsPortal.Models.Entities
@{
    Layout = "_AgentLayout";
    ViewData["Title"] = "Leads Management";
    ViewData["PageHeading"] = "Leads Management";
    var leads       = ViewBag.Leads as List<PropertyEnquiry> ?? new();
    var totalLeads  = (int)(ViewBag.TotalLeads ?? 0);
    var unreadCount = (int)(ViewBag.UnreadCount ?? 0);
    var totalPages  = (int)(ViewBag.TotalPages ?? 1);
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var selectedStatus = ViewBag.SelectedStatus as string ?? "all";
    var myProperties = ViewBag.MyProperties as List<dynamic> ?? new();
}

<main class="p-6 lg:p-8 space-y-6">

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4" data-aos="fade-up">
        <div class="glass-card rounded-xl p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-purple-500/20 text-purple-400 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-users text-xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold text-white">@totalLeads</p>
                <p class="text-xs text-gray-400">Total Leads</p>
            </div>
        </div>
        <div class="glass-card rounded-xl p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-blue-500/20 text-blue-400 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-envelope text-xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold text-white">@unreadCount</p>
                <p class="text-xs text-gray-400">Unread</p>
            </div>
        </div>
        <div class="glass-card rounded-xl p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-green-500/20 text-green-400 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-envelope-open text-xl"></i>
            </div>
            <div>
                <p class="text-3xl font-bold text-white">@(totalLeads - unreadCount)</p>
                <p class="text-xs text-gray-400">Read</p>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" asp-controller="Agent" asp-action="Leads">
        <div class="glass-card rounded-xl p-4 flex flex-wrap gap-3 items-center">
            <span class="text-sm text-gray-400 font-medium">Filter By:</span>
            <select name="status" class="agent-select text-sm" onchange="this.form.submit()">
                <option value="all" selected="@(selectedStatus == "all")">All Status</option>
                <option value="unread" selected="@(selectedStatus == "unread")">Unread</option>
                <option value="read" selected="@(selectedStatus == "read")">Read</option>
            </select>
            <button type="submit" class="btn-outline-agent text-sm px-4 py-2">Apply</button>
        </div>
    </form>

    <!-- Table -->
    <div class="glass-card rounded-2xl overflow-hidden" data-aos="fade-up">
        @if (!leads.Any())
        {
            <div class="text-center py-16">
                <i class="fa-solid fa-inbox text-5xl text-gray-600 mb-4 block"></i>
                <h3 class="text-lg font-bold text-white mb-2">No Leads Yet</h3>
                <p class="text-gray-400 text-sm">Leads will appear here when visitors enquire about your listings.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left glass-table min-w-[700px]">
                    <thead>
                        <tr>
                            <th class="p-4 pl-6">Client</th>
                            <th class="p-4">Contact</th>
                            <th class="p-4">Property</th>
                            <th class="p-4">Date</th>
                            <th class="p-4">Status</th>
                            <th class="p-4 pr-6 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lead in leads)
                        {
                            <tr>
                                <td class="p-4 pl-6">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-full bg-purple-500/20 text-purple-300 flex items-center justify-center text-sm font-bold flex-shrink-0">
                                            @(lead.FullName.Length > 0 ? lead.FullName[0].ToString().ToUpper() : "?")
                                        </div>
                                        <div>
                                            <p class="font-medium text-white text-sm">@lead.FullName</p>
                                            <p class="text-xs text-gray-400">@lead.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-4 text-gray-300 text-sm">@(lead.Phone ?? "—")</td>
                                <td class="p-4">
                                    <p class="text-sm text-gray-300 line-clamp-1">@(lead.Property?.Title ?? "Property #" + lead.PropertyId)</p>
                                </td>
                                <td class="p-4 text-sm text-gray-400">@lead.SubmittedAt.ToString("MMM dd, yyyy")</td>
                                <td class="p-4">
                                    @if (lead.IsRead)
                                    {
                                        <span class="px-2 py-1 rounded-full text-xs font-medium badge-read">Read</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-1 rounded-full text-xs font-medium badge-new">New</span>
                                    }
                                </td>
                                <td class="p-4 pr-6 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        @if (!string.IsNullOrEmpty(lead.Message))
                                        {
                                            <button type="button" title="@lead.Message"
                                                    onclick="showMsg(this)"
                                                    class="text-xs text-blue-400 hover:text-blue-300 transition-theme px-2 py-1 rounded glass-card border border-white/10">
                                                <i class="fa-regular fa-envelope"></i> View
                                            </button>
                                        }
                                        @if (!lead.IsRead)
                                        {
                                            <form asp-controller="Agent" asp-action="MarkLeadRead" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@lead.Id">
                                                <button type="submit" class="text-xs text-green-400 hover:text-green-300 transition-theme px-2 py-1 rounded glass-card border border-white/10" title="Mark as read">
                                                    <i class="fa-solid fa-check"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-controller="Agent" asp-action="DeleteLead" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@lead.Id">
                                            <button type="submit" class="text-xs text-red-400 hover:text-red-300 transition-theme px-2 py-1 rounded glass-card border border-red-500/20" title="Delete">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="p-4 border-t border-white/10 flex items-center justify-between text-sm text-gray-400">
                    <span>Showing page @currentPage of @totalPages</span>
                    <div class="flex gap-1">
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <a asp-action="Leads" asp-route-page="@i" asp-route-status="@selectedStatus"
                               class="px-3 py-1 rounded text-sm transition-theme @(i == currentPage ? "bg-gold-500 text-navy-900 font-bold" : "bg-white/5 hover:bg-white/10 border border-white/10")">@i</a>
                        }
                    </div>
                </div>
            }
        }
    </div>
</main>

<!-- Message modal -->
<div id="msgModal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
    <div class="glass-card rounded-2xl p-6 max-w-md w-full border border-white/10">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-white">Client Message</h3>
            <button onclick="document.getElementById('msgModal').classList.add('hidden')" class="text-gray-400 hover:text-white" title="Close" aria-label="Close"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <p id="msgContent" class="text-gray-300 text-sm leading-relaxed"></p>
    </div>
</div>

@section Scripts {
<script>
    function showMsg(btn) {
        document.getElementById('msgContent').textContent = btn.title;
        document.getElementById('msgModal').classList.remove('hidden');
    }
</script>
}
