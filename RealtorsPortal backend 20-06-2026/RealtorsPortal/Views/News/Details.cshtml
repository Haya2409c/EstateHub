@model RealtorsPortal.Models.ViewModels.News.NewsArticleDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
    var thumb = Model.ThumbnailUrl ?? "https://images.unsplash.com/photo-1560184897-ae75f418493e?auto=format&fit=crop&w=1200&q=80";
}

<!-- Hero -->
<section class="pt-32 pb-0 relative overflow-hidden bg-deep">
    <div class="absolute inset-0">
        <img src="@thumb" alt="@Model.Title" class="w-full h-full object-cover opacity-20"
             onerror="this.src='https://images.unsplash.com/photo-1560184897-ae75f418493e?auto=format&fit=crop&w=1200&q=80'">
        <div class="absolute inset-0 bg-[#0F2040]/70"></div>
    </div>
    <div class="container mx-auto px-6 pb-16 relative z-10">
        <div class="max-w-3xl mx-auto text-center">
            <a asp-controller="News" asp-action="Index"
               class="inline-flex items-center gap-2 text-gold text-sm font-semibold mb-6 hover:text-white transition-colors">
                <i class="fas fa-arrow-left text-xs"></i> Back to News
            </a>
            <div class="flex items-center justify-center gap-4 mb-6 text-sm text-white/60">
                @if (!string.IsNullOrEmpty(Model.Author))
                {
                    <span><i class="fas fa-user mr-1"></i>@Model.Author</span>
                    <span>·</span>
                }
                <span><i class="fas fa-calendar mr-1"></i>@Model.PublishedAt.ToString("MMMM dd, yyyy")</span>
            </div>
            <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight">@Model.Title</h1>
            @if (!string.IsNullOrEmpty(Model.Summary))
            {
                <p class="mt-6 text-white/75 text-lg leading-relaxed">@Model.Summary</p>
            }
        </div>
    </div>
</section>

<!-- Article Body -->
<section class="py-20">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">

            <!-- Content -->
            <article class="lg:col-span-2" data-aos="fade-up">
                <div class="h-96 rounded-3xl overflow-hidden mb-12">
                    <img src="@thumb" alt="@Model.Title"
                         class="w-full h-full object-cover"
                         onerror="this.src='https://images.unsplash.com/photo-1560184897-ae75f418493e?auto=format&fit=crop&w=1200&q=80'">
                </div>
                <div class="prose prose-lg max-w-none text-[#374151] leading-relaxed space-y-4">
                    @Html.Raw(Model.Content)
                </div>
            </article>

            <!-- Sidebar -->
            <aside class="space-y-10" data-aos="fade-left">
                @if (Model.RelatedArticles.Any())
                {
                    <div class="glass-panel p-8 rounded-3xl">
                        <h3 class="text-xl font-bold mb-6 border-b border-gray-200 pb-4">Related Articles</h3>
                        <div class="space-y-6">
                            @foreach (var related in Model.RelatedArticles)
                            {
                                var rThumb = related.ThumbnailUrl ?? "https://images.unsplash.com/photo-1560184897-ae75f418493e?auto=format&fit=crop&w=200&q=80";
                                <a asp-controller="News" asp-action="Details" asp-route-id="@related.Id"
                                   class="flex gap-4 group">
                                    <img src="@rThumb" alt="@related.Title"
                                         class="w-20 h-16 rounded-xl object-cover flex-shrink-0"
                                         onerror="this.src='https://images.unsplash.com/photo-1560184897-ae75f418493e?auto=format&fit=crop&w=200&q=80'">
                                    <div>
                                        <h4 class="font-bold text-sm group-hover:text-gold transition-colors line-clamp-2">@related.Title</h4>
                                        <p class="text-xs text-gray-500 mt-1">@related.PublishedAt.ToString("MMM dd, yyyy")</p>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                }

                <div class="glass-panel p-8 rounded-3xl">
                    <h3 class="text-xl font-bold mb-4">Need Help?</h3>
                    <p class="text-gray-500 text-sm mb-6">Our team is available to answer your real estate questions.</p>
                    <a asp-controller="Contact" asp-action="Index"
                       class="block w-full text-center btn-gold py-3">Contact Us</a>
                </div>
            </aside>
        </div>
    </div>
</section>

<!-- Footer -->

@section Scripts {
    <script>
        AOS.init({ duration: 800, once: true, offset: 0 });
        window.addEventListener('load', function() { AOS.refresh(); });
    </script>
}
